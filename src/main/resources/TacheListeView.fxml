<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="700" prefWidth="1000" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.TacheListeController">

    <!-- Header -->
    <VBox layoutX="0" layoutY="0" prefWidth="1000" style="-fx-background-color: #2c3e50;">
        <HBox alignment="CENTER_LEFT" prefHeight="70" spacing="20" style="-fx-padding: 0 30;">
            <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="📋 LISTE DES TÂCHES" />
        </HBox>
    </VBox>

    <!-- Statistiques -->
    <HBox layoutX="30" layoutY="90" prefWidth="940" spacing="20">
        <VBox spacing="5" style="-fx-background-color: #eff6ff; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 14px; -fx-text-fill: #1e40af;" text="Total tâches" />
            <Label fx:id="lblTotalTaches" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1e40af;" text="0" />
        </VBox>
        <VBox spacing="5" style="-fx-background-color: #fef9c3; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 14px; -fx-text-fill: #854d0e;" text="À faire" />
            <Label fx:id="lblAFaire" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #854d0e;" text="0" />
        </VBox>
        <VBox spacing="5" style="-fx-background-color: #fed7aa; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 14px; -fx-text-fill: #9a3412;" text="En cours" />
            <Label fx:id="lblEnCours" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #9a3412;" text="0" />
        </VBox>
        <VBox spacing="5" style="-fx-background-color: #dcfce7; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 14px; -fx-text-fill: #166534;" text="Terminées" />
            <Label fx:id="lblTerminees" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #166534;" text="0" />
        </VBox>
    </HBox>

    <!-- Tableau -->
    <VBox layoutX="30" layoutY="220" prefHeight="400" prefWidth="940" spacing="10">
        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="📋 Tâches enregistrées" />

        <TableView fx:id="tableTaches" prefHeight="350" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e2e8f0;">
            <columns>
                <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                <TableColumn fx:id="colPriorite" prefWidth="50" text="Prio" />
                <TableColumn fx:id="colTitre" prefWidth="200" text="Titre" />
                <TableColumn fx:id="colEmploye" prefWidth="120" text="Employé" />
                <TableColumn fx:id="colDeadline" prefWidth="100" text="Deadline" />
                <TableColumn fx:id="colStatut" prefWidth="100" text="Statut" />
                <TableColumn fx:id="colProjet" prefWidth="80" text="Projet" />
                <TableColumn fx:id="colActions" prefWidth="100" text="Actions" />
            </columns>
        </TableView>
    </VBox>

    <!-- Bouton retour -->
    <Button layoutX="30" layoutY="640" onAction="#retourFormulaire"
            style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"
            text="← Retour au formulaire" />
</AnchorPane>