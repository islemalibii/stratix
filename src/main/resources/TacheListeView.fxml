<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700" prefWidth="1000" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.TacheListeController">

    <top>
        <VBox spacing="0">
            <!-- Barre de navigation -->
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 15 30 10 30; -fx-background-color: #f0f2f5;">
                <Button onAction="#showDashboardFromButton" text="🏠 Dashboard"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showPlanningFromButton" text="📅 Planning"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showTachesFromButton" text="📋 Tâches"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showCalendarFromButton" text="📆 Calendrier"
                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showWhiteboardFromButton" text="📋 Whiteboard"
                        style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>

            <!-- En-tête avec titre et boutons d'export -->
            <HBox alignment="CENTER_LEFT" prefHeight="70" spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 0 30;">
                <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="📋 " />
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <TextField fx:id="searchField" promptText="Rechercher une tâche..."
                               style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 8 15; -fx-pref-width: 250;" />
                    <Button text="📄 PDF" onAction="#exportToPDF"
                            style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
                    <Button text="📊 Excel" onAction="#exportToExcel"
                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
                    <Button text="📊 Stats" onAction="#showStatistics"
                            style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="20" style="-fx-padding: 30;">
                <!-- Statistiques en cartes -->
                <HBox spacing="20">
                    <VBox spacing="5" style="-fx-background-color: #eff6ff; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #1e40af; -fx-font-weight: bold;" text="TOTAL TÂCHES" />
                        <Label fx:id="lblTotalTaches" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #1e40af;" text="0" />
                    </VBox>
                    <VBox spacing="5" style="-fx-background-color: #fef9c3; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #854d0e; -fx-font-weight: bold;" text="À FAIRE" />
                        <Label fx:id="lblAFaire" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #854d0e;" text="0" />
                    </VBox>
                    <VBox spacing="5" style="-fx-background-color: #fed7aa; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #9a3412; -fx-font-weight: bold;" text="EN COURS" />
                        <Label fx:id="lblEnCours" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #9a3412;" text="0" />
                    </VBox>
                    <VBox spacing="5" style="-fx-background-color: #dcfce7; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #166534; -fx-font-weight: bold;" text="TERMINÉES" />
                        <Label fx:id="lblTerminees" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #166534;" text="0" />
                    </VBox>
                </HBox>

                <!-- Titre de la section -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-font-size: 24px;" text="📌" />
                    <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Tâches enregistrées" />
                    <Label fx:id="lblTachesCount" style="-fx-font-size: 14px; -fx-background-color: #e2e8f0; -fx-padding: 5 12; -fx-background-radius: 20; -fx-text-fill: #475569;" text="0 tâches" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="➕ Nouvelle tâche" onAction="#nouvelleTache"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
                </HBox>

                <!-- Liste des tâches en cartes -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <VBox fx:id="cardsContainer" spacing="10" style="-fx-padding: 0 0 20 0;">
                        <!-- Les cartes seront générées dynamiquement -->
                    </VBox>
                </ScrollPane>

                <!-- Bouton retour -->
                <Button onAction="#retourFormulaire"
                        style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand; -fx-max-width: 200;"
                        text="← Retour au formulaire" />
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>