<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700" prefWidth="1000" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.TacheListeController">

    <top>
        <VBox spacing="0">
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 15 30 10 30; -fx-background-color: #f0f2f5;">
                <Button onAction="#showDashboardFromButton" text="🏠 Dashboard"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showPlanningFromButton" text="📅 Planning"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showTachesFromButton" text="📋 Tâches"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showCalendarFromButton" text="📆 Calendrier"
                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showWhiteboardFromButton" text="📋 Whiteboard"
                        style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>

            <HBox alignment="CENTER_LEFT" prefHeight="70" spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 0 30;">
                <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="📋 LISTE DES TÂCHES" />
                <HBox spacing="10" alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                    <Button text="📄 PDF" onAction="#exportToPDF"
                            style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
                    <Button text="📊 Excel" onAction="#exportToExcel"
                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
                    <Button text="📊 Stats" onAction="#showStatistics"
                            style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="20" style="-fx-padding: 30;">
                <HBox spacing="20">
                    <VBox spacing="5" style="-fx-background-color: #eff6ff; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #1e40af;" text="Total tâches" />
                        <Label fx:id="lblTotalTaches" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1e40af;" text="0" />
                    </VBox>
                    <VBox spacing="5" style="-fx-background-color: #fef9c3; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #854d0e;" text="À faire" />
                        <Label fx:id="lblAFaire" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #854d0e;" text="0" />
                    </VBox>
                    <VBox spacing="5" style="-fx-background-color: #fed7aa; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #9a3412;" text="En cours" />
                        <Label fx:id="lblEnCours" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #9a3412;" text="0" />
                    </VBox>
                    <VBox spacing="5" style="-fx-background-color: #dcfce7; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #166534;" text="Terminées" />
                        <Label fx:id="lblTerminees" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #166534;" text="0" />
                    </VBox>
                </HBox>

                <VBox spacing="10">
                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="📋 Tâches enregistrées" />
                    <TableView fx:id="tableTaches" prefHeight="400" style="-fx-background-radius: 10; -fx-border-radius: 10;">
                        <columns>
                            <TableColumn fx:id="colPriorite" prefWidth="50" text="Prio" />
                            <TableColumn fx:id="colTitre" prefWidth="200" text="Titre" />
                            <TableColumn fx:id="colEmploye" prefWidth="120" text="Employé" />
                            <TableColumn fx:id="colDeadline" prefWidth="100" text="Deadline" />
                            <TableColumn fx:id="colStatut" prefWidth="120" text="Statut" />
                            <TableColumn fx:id="colProjet" prefWidth="80" text="Projet" />
                            <TableColumn fx:id="colActions" prefWidth="120" text="Actions" />
                        </columns>
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    </TableView>
                </VBox>

                <Button onAction="#retourFormulaire"
                        style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"
                        text="← Retour au formulaire" />
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>