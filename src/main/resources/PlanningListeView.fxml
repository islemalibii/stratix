<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="800" prefWidth="1100" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PlanningListeController">

    <top>
        <VBox spacing="0">
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 15 30 10 30; -fx-background-color: #f8fafc;">
                <Button onAction="#showDashboardFromButton" text="🏠 Dashboard"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showPlanningFromButton" text="📅 Planning"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showTachesFromButton" text="📋 Tâches"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showCalendarFromButton" text="📆 Calendrier"
                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showWhiteboardFromButton" text="📋 Whiteboard"
                        style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>

            <HBox alignment="CENTER_LEFT" prefHeight="80" spacing="20" style="-fx-background-color: linear-gradient(to right, #1e293b, #0f172a); -fx-padding: 0 30;">
                <Label style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" text="📋 LISTE DES PLANNINGS" />
                <Circle radius="8" fill="#4ade80"/>
                <Label fx:id="lblHeaderStats" style="-fx-text-fill: #94a3b8; -fx-font-size: 16px;" text="Visualisation globale"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 30;">

                <HBox spacing="15" style="-fx-margin-bottom: 20;">
                    <VBox spacing="5" style="-fx-background-color: #4e73df; -fx-background-radius: 10; -fx-padding: 15;" HBox.hgrow="ALWAYS">
                        <Label text="TOTAL" textFill="WHITE" style="-fx-font-weight: bold;"/>
                        <Label fx:id="lblTotalPlannings" text="0" textFill="WHITE" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox spacing="5" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                        <Label text="☀️ JOUR" style="-fx-font-weight: bold; -fx-text-fill: #f6c23e;"/>
                        <Label fx:id="lblTotalJour" text="0" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox spacing="5" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                        <Label text="🌆 SOIR" style="-fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
                        <Label fx:id="lblTotalSoir" text="0" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox spacing="5" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                        <Label text="🌙 NUIT" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <Label fx:id="lblTotalNuit" text="0" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox spacing="5" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                        <Label text="🌴 CONGÉS" style="-fx-font-weight: bold; -fx-text-fill: #1cc88a;"/>
                        <Label fx:id="lblConges" text="0" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox spacing="5" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                        <Label text="🤒 MALADIE" style="-fx-font-weight: bold; -fx-text-fill: #e74a3b;"/>
                        <Label fx:id="lblMaladie" text="0" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox spacing="5" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                        <Label text="🎓 FORMATION" style="-fx-font-weight: bold; -fx-text-fill: #36b9cc;"/>
                        <Label fx:id="lblFormation" text="0" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox spacing="5" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                        <Label text="❓ AUTRE" style="-fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                        <Label fx:id="lblAutre" text="0" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>

                <VBox spacing="10">
                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="🌤️ MÉTÉO"/>
                    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 0);">
                        <Circle radius="15" fill="#3b82f6" opacity="0.2"/>
                        <Label fx:id="lblMeteo" style="-fx-font-size: 16px; -fx-text-fill: #1e293b;" text="Sélectionnez un planning pour voir la météo"/>
                    </HBox>
                </VBox>

                <VBox spacing="10">
                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="📅 PLANNINGS ENREGISTRÉS"/>
                    <TableView fx:id="tablePlannings" prefHeight="400" style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #e2e8f0;">
                        <columns>
                            <TableColumn fx:id="colEmploye" prefWidth="180" text="Employé" />
                            <TableColumn fx:id="colDate" prefWidth="120" text="Date" />
                            <TableColumn fx:id="colHeureDebut" prefWidth="100" text="Début" />
                            <TableColumn fx:id="colHeureFin" prefWidth="100" text="Fin" />
                            <TableColumn fx:id="colTypeShift" prefWidth="150" text="Type" />
                            <TableColumn fx:id="colActions" prefWidth="130" text="Actions" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <HBox alignment="CENTER">
                    <Button onAction="#retourFormulaire"
                            style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 30; -fx-background-radius: 30; -fx-cursor: hand;"
                            text="← Retour au Formulaire" />
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>