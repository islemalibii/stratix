<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="800" prefWidth="1100" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PlanningListeController">

    <top>
        <VBox spacing="0">
            <!-- Barre de navigation -->
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 15 30 10 30; -fx-background-color: #f8fafc;">
                <Button onAction="#showDashboardFromButton" text="🏠 Dashboard"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showPlanningFromButton" text="📅 Planning"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showTachesFromButton" text="📋 Tâches"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showCalendarFromButton" text="📆 Calendrier"
                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showWhiteboardFromButton" text="📋 Whiteboard"
                        style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>

            <!-- En-tête avec titre et petits boutons -->
            <HBox alignment="CENTER_LEFT" prefHeight="70" spacing="15" style="-fx-background-color: linear-gradient(to right, #1e293b, #0f172a); -fx-padding: 0 30;">
                <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="📅 LISTE DES PLANNINGS" />
                <Circle radius="6" fill="#4ade80"/>
                <Label fx:id="lblHeaderStats" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;" text="Visualisation globale - 24 planning(s)"/>
                <Region HBox.hgrow="ALWAYS" />

                <!-- Petits boutons d'export discrets -->
                <Button onAction="#exportToPDF" text="PDF"
                        style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 5 10; -fx-background-radius: 3; -fx-cursor: hand;" />
                <Button onAction="#exportToExcel" text="Excel"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 5 10; -fx-background-radius: 3; -fx-cursor: hand;" />
                <Button onAction="#showStatistics" text="Stats"
                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 5 10; -fx-background-radius: 3; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 25;">

                <!-- Statistiques en petites cartes -->
                <HBox spacing="10">
                    <VBox spacing="2" style="-fx-background-color: #4e73df; -fx-background-radius: 8; -fx-padding: 12;" HBox.hgrow="ALWAYS">
                        <Label text="TOTAL" textFill="WHITE" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="lblTotalPlannings" text="0" textFill="WHITE" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox spacing="2" style="-fx-background-color: #f6c23e; -fx-background-radius: 8; -fx-padding: 12;" HBox.hgrow="ALWAYS">
                        <Label text="JOUR" textFill="WHITE" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="lblTotalJour" text="0" textFill="WHITE" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox spacing="2" style="-fx-background-color: #3b82f6; -fx-background-radius: 8; -fx-padding: 12;" HBox.hgrow="ALWAYS">
                        <Label text="SOIR" textFill="WHITE" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="lblTotalSoir" text="0" textFill="WHITE" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox spacing="2" style="-fx-background-color: #1e293b; -fx-background-radius: 8; -fx-padding: 12;" HBox.hgrow="ALWAYS">
                        <Label text="NUIT" textFill="WHITE" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="lblTotalNuit" text="0" textFill="WHITE" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox spacing="2" style="-fx-background-color: #1cc88a; -fx-background-radius: 8; -fx-padding: 12;" HBox.hgrow="ALWAYS">
                        <Label text="CONGÉS" textFill="WHITE" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="lblConges" text="0" textFill="WHITE" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox spacing="2" style="-fx-background-color: #e74a3b; -fx-background-radius: 8; -fx-padding: 12;" HBox.hgrow="ALWAYS">
                        <Label text="MALADIE" textFill="WHITE" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="lblMaladie" text="0" textFill="WHITE" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox spacing="2" style="-fx-background-color: #36b9cc; -fx-background-radius: 8; -fx-padding: 12;" HBox.hgrow="ALWAYS">
                        <Label text="FORMATION" textFill="WHITE" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="lblFormation" text="0" textFill="WHITE" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox spacing="2" style="-fx-background-color: #64748b; -fx-background-radius: 8; -fx-padding: 12;" HBox.hgrow="ALWAYS">
                        <Label text="AUTRE" textFill="WHITE" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="lblAutre" text="0" textFill="WHITE" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>

                <!-- Widget Météo compact -->
                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 0);">
                    <Label text="🌤️" style="-fx-font-size: 18px;"/>
                    <Label fx:id="lblMeteo" style="-fx-font-size: 13px; -fx-text-fill: #1e293b;" text="Sélectionnez un planning pour voir la météo"/>
                </HBox>

                <!-- Titre de la section avec bouton Nouveau planning -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="📅 Plannings enregistrés" />
                    <Label fx:id="lblPlanningCount" style="-fx-font-size: 12px; -fx-background-color: #e2e8f0; -fx-padding: 3 10; -fx-background-radius: 15; -fx-text-fill: #475569;" text="0 planning" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="+ Nouveau planning" onAction="#nouveauPlanning"
                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 5 15; -fx-background-radius: 15; -fx-cursor: hand;"/>
                </HBox>

                <!-- Liste des plannings en cartes -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <VBox fx:id="cardsContainer" spacing="8" style="-fx-padding: 0 0 15 0;">
                        <!-- Les cartes seront générées dynamiquement -->
                    </VBox>
                </ScrollPane>

                <!-- Bouton retour discret -->
                <HBox alignment="CENTER">
                    <Button onAction="#retourFormulaire"
                            style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8 25; -fx-background-radius: 20; -fx-cursor: hand;"
                            text="← Retour au formulaire" />
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>