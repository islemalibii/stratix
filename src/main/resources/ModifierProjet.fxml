<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="500.0" spacing="20.0" styleClass="form-container" xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ModifierProjetController">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <children>
        <Label text="Modifier le Projet" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" />
        <Separator prefWidth="200.0" />

        <VBox spacing="8.0">
            <Label text="Nom du projet" styleClass="input-label" />
            <TextField fx:id="txtNom" styleClass="modern-input" promptText="Ex: Refonte Site Web" />
        </VBox>

        <VBox spacing="8.0">
            <Label text="Description" styleClass="input-label" />
            <TextArea fx:id="txtDescription" prefHeight="100.0" styleClass="modern-input" wrapText="true" />
        </VBox>

        <GridPane hgap="20.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <children>
                <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Date Début" styleClass="input-label" />
                    <DatePicker fx:id="dateDebut" maxWidth="Infinity" styleClass="modern-datepicker" />
                </VBox>
                <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Date Fin" styleClass="input-label" />
                    <DatePicker fx:id="dateFin" maxWidth="Infinity" styleClass="modern-datepicker" />
                </VBox>
                <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Budget (DT)" styleClass="input-label" />
                    <TextField fx:id="txtBudget" styleClass="modern-input" />
                </VBox>
                <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Progression (%)" styleClass="input-label" />
                    <TextField fx:id="txtProgression" styleClass="modern-input" />
                </VBox>
            </children>
        </GridPane>

        <VBox spacing="8.0">
            <Label text="Statut du projet" styleClass="input-label" />
            <ChoiceBox fx:id="comboStatut" maxWidth="Infinity" styleClass="modern-choicebox">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="Planifié" />
                        <String fx:value="En cours" />
                        <String fx:value="Terminé" />
                        <String fx:value="Annulé" />
                    </FXCollections>
                </items>
            </ChoiceBox>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 10 0 0 0;">
            <Button onAction="#handleAnnuler" styleClass="btn-cancel" text="Annuler" />
            <Button onAction="#handleEnregistrer" styleClass="btn-save" text="Enregistrer les modifications" />
        </HBox>
    </children>
</VBox>