<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="50" style="-fx-background-color: linear-gradient(to bottom, #f0f9ff, #e6f0fa); -fx-padding: 50;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PagePrincipaleController">

    <Label style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="📊 STRATIX">
        <font><Font name="Segoe UI Bold" size="48" /></font>
    </Label>

    <Label style="-fx-font-size: 18px; -fx-text-fill: #475569;" text="Choisissez votre espace de travail" />

    <HBox alignment="CENTER" spacing="50">

        <!-- Carte Espace Employé -->
        <VBox prefHeight="300" prefWidth="300" spacing="20" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 20, 0, 0, 0);">
            <Label prefHeight="94.0" prefWidth="143.0" style="-fx-font-size: 64px;" text="👤" />
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="ESPACE EMPLOYÉ" />
            <Button fx:id="btnEspaceEmploye" onAction="#openEspaceEmploye" prefWidth="200" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 15 30; -fx-background-radius: 30; -fx-cursor: hand;" text="ENTRER" />
        </VBox>

        <!-- Carte Dashboard Général -->
        <VBox prefHeight="300" prefWidth="300" spacing="20" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 20, 0, 0, 0);">
            <Label style="-fx-font-size: 64px;" text=" 📊" />
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="DASHBOARD GÉNÉRAL" />
            <Button fx:id="btnDashboardGeneral" onAction="#openDashboardGeneral" prefWidth="200" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 15 30; -fx-background-radius: 30; -fx-cursor: hand;" text="ENTRER" />
        </VBox>

    </HBox>

    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;" text="© 2026 Stratix - Tous droits réservés" />
</VBox>
