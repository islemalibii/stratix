<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.FormulaireProduitController"
            prefHeight="650" prefWidth="550"
            style="-fx-background-color: white;">

    <!-- En-tête -->
    <top>
        <VBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 20;">
            <Label fx:id="titreFormulaire" text="Ajouter un produit"
                   style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold; -fx-alignment: center;"/>
        </VBox>
    </top>

    <!-- Centre avec formulaire -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="15" style="-fx-padding: 25;">

                <!-- GridPane pour organiser les champs -->
                <GridPane hgap="15" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="30"/>
                        <ColumnConstraints percentWidth="70"/>
                    </columnConstraints>

                    <!-- ID caché -->
                    <TextField fx:id="idField" visible="false" managed="false"/>

                    <!-- Ligne 0: Nom -->
                    <Label text="Nom du produit :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="nomField" promptText="Ex: Ordinateur portable"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <!-- Ligne 1: Description -->
                    <Label text="Description :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextArea fx:id="descriptionField" promptText="Description détaillée..."
                              prefRowCount="3" wrapText="true"
                              GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <!-- Ligne 2: Catégorie -->
                    <Label text="Catégorie :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="categorieCombo" promptText="Choisir une catégorie"
                              editable="true" prefWidth="300"
                              GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <!-- Ligne 3: Prix -->
                    <Label text="Prix (DT) :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="prixField" promptText="Ex: 1299.99"
                               GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <!-- Ligne 4: Stock Actuel -->
                    <Label text="Stock actuel :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <TextField fx:id="stockActuelField" promptText="Ex: 50"
                               GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                    <!-- Ligne 5: Stock Minimum -->
                    <Label text="Stock minimum :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <TextField fx:id="stockMinField" promptText="Ex: 10"
                               GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                    <!-- Ligne 6: Date création -->
                    <Label text="Date création :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                    <DatePicker fx:id="dateCreationPicker" promptText="jj/mm/aaaa"
                                GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                    <!-- Ligne 7: Ressources nécessaires -->
                    <Label text="Ressources :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                    <TextArea fx:id="ressourcesField" promptText="Ressources nécessaires..."
                              prefRowCount="2" wrapText="true"
                              GridPane.rowIndex="7" GridPane.columnIndex="1"/>
                </GridPane>

                <!-- Séparateur -->
                <Separator/>

                <!-- Boutons -->
                <HBox spacing="15" alignment="CENTER">
                    <Button fx:id="btnValider" text="Ajouter"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 10 30;"
                            onAction="#validerFormulaire"/>
                    <Button text="Annuler"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 10 30;"
                            onAction="#annulerFormulaire"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- Pied de page -->
    <bottom>
        <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 10;" alignment="CENTER">
            <Label text="* Tous les champs sont obligatoires" style="-fx-text-fill: #7f8c8d; -fx-font-style: italic;"/>
        </HBox>
    </bottom>
</BorderPane>