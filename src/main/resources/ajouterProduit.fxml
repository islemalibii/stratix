<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.FormulaireProduitController"
            prefHeight="850" prefWidth="600"
            style="-fx-background-color: white;">

    <top>
        <VBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 20;">
            <Label fx:id="titreFormulaire" text="Ajouter un produit"
                   style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold; -fx-alignment: center;"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="15" style="-fx-padding: 25;">

                <!-- SECTION IMAGE -->
                <TitledPane text="Image du produit" expanded="true"
                            style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
                    <VBox spacing="10" alignment="CENTER" style="-fx-padding: 15;">
                        <ImageView fx:id="imageView" fitHeight="150" fitWidth="200"
                                   preserveRatio="true"
                                   style="-fx-border-color: #ced4da; -fx-border-width: 2; -fx-border-radius: 5; -fx-background-color: #f8f9fa;">
                            <VBox.margin>
                                <Insets bottom="10"/>
                            </VBox.margin>
                        </ImageView>
                        <Label fx:id="cheminImageLabel" text="Aucune image sélectionnée"
                               style="-fx-text-fill: #6c757d; -fx-font-style: italic;"/>
                        <HBox spacing="10" alignment="CENTER">
                            <Button fx:id="btnChoisirImage" text="Choisir une image"
                                    onAction="#choisirImage"
                                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15;"/>
                            <Button fx:id="btnSupprimerImage" text="Supprimer"
                                    onAction="#supprimerImage"
                                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15;"/>
                        </HBox>
                        <Label text="Formats supportés: PNG, JPG, JPEG, GIF, BMP"
                               style="-fx-text-fill: #95a5a6; -fx-font-size: 11;"/>
                    </VBox>
                </TitledPane>

                <Separator/>

                <!-- GridPane pour organiser les champs -->
                <GridPane hgap="15" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="30"/>
                        <ColumnConstraints percentWidth="70"/>
                    </columnConstraints>

                    <!-- ID caché -->
                    <TextField fx:id="idField" visible="false" managed="false"/>

                    <!-- Ligne 0: Nom -->
                    <Label text="Nom du produit :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="nomField" promptText="Ex: Ordinateur portable"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <!-- Ligne 1: Description -->
                    <Label text="Description :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextArea fx:id="descriptionField" promptText="Description détaillée..."
                              prefRowCount="3" wrapText="true"
                              GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <!-- Ligne 2: Catégorie -->
                    <Label text="Catégorie :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="categorieCombo" promptText="Choisir une catégorie"
                              prefWidth="300"
                              GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <!-- Zone pour catégorie personnalisée -->
                    <VBox fx:id="autreCategorieContainer" spacing="5"
                          GridPane.rowIndex="3" GridPane.columnIndex="1"
                          managed="false" visible="false">
                        <Label text="Catégorie personnalisée :" style="-fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                        <TextField fx:id="autreCategorieField" promptText="Saisissez votre catégorie..."
                                   style="-fx-background-color: #fff3cd; -fx-border-color: #ffeeba;"/>
                    </VBox>

                    <!-- Ligne 4: Prix -->
                    <Label text="Prix (DT) :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <TextField fx:id="prixField" promptText="Ex: 1299.99"
                               GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                    <!-- Ligne 5: Stock Actuel -->
                    <Label text="Stock actuel :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <TextField fx:id="stockActuelField" promptText="Ex: 50"
                               GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                    <!-- Ligne 6: Stock Minimum -->
                    <Label text="Stock minimum :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                    <TextField fx:id="stockMinField" promptText="Ex: 10"
                               GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                    <!-- Ligne 7: Date création (SYSTÈME - NON MODIFIABLE) -->
                    <Label text="Date création :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                    <DatePicker fx:id="dateCreationPicker" promptText="jj/mm/aaaa"
                                GridPane.rowIndex="7" GridPane.columnIndex="1"
                                editable="false"/>

                    <!-- Ligne 8: Ressources nécessaires -->
                    <Label text="Ressources :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                    <TextArea fx:id="ressourcesField" promptText="Ressources nécessaires..."
                              prefRowCount="2" wrapText="true"
                              GridPane.rowIndex="8" GridPane.columnIndex="1"/>

                    <!-- Ligne 9: Date fabrication -->
                    <Label text="Date fabrication :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="9" GridPane.columnIndex="0"/>
                    <DatePicker fx:id="dateFabricationPicker" promptText="jj/mm/aaaa"
                                GridPane.rowIndex="9" GridPane.columnIndex="1"
                                editable="true"/>

                    <!-- Ligne 10: Date péremption -->
                    <Label text="Date péremption :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="10" GridPane.columnIndex="0"/>
                    <VBox GridPane.rowIndex="10" GridPane.columnIndex="1" spacing="5">
                        <DatePicker fx:id="datePeremptionPicker" promptText="jj/mm/aaaa"
                                    maxWidth="Infinity" editable="true"/>
                        <Label fx:id="statutPeremptionLabel" text="" style="-fx-font-size: 11px;"/>
                    </VBox>

                    <!-- Ligne 11: Date garantie -->
                    <Label text="Date garantie :" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="11" GridPane.columnIndex="0"/>
                    <DatePicker fx:id="dateGarantiePicker" promptText="jj/mm/aaaa"
                                GridPane.rowIndex="11" GridPane.columnIndex="1"
                                editable="true"/>
                </GridPane>

                <Separator/>

                <!-- Boutons -->
                <HBox spacing="15" alignment="CENTER">
                    <Button fx:id="btnValider" text="Ajouter"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 10 30;"
                            onAction="#validerFormulaire"/>
                    <Button text="Annuler"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 10 30;"
                            onAction="#annulerFormulaire"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 10;" alignment="CENTER">
            <Label text="* Tous les champs sont obligatoires" style="-fx-text-fill: #7f8c8d; -fx-font-style: italic;"/>
        </HBox>
    </bottom>
</BorderPane>