<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane"
            xmlns="http://javafx.com/javafx/20"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.EventDetailsEmployeeController">
    <content>
        <VBox spacing="20" style="-fx-padding: 30;">
            <Button text="← Retour" onAction="#goBack" styleClass="btn-secondary" />

            <HBox spacing="40" styleClass="card" style="-fx-padding: 30; -fx-background-radius: 20; -fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">

                <VBox alignment="TOP_CENTER">
                    <ImageView fx:id="eventImageView" fitHeight="350.0" fitWidth="450.0" pickOnBounds="true" preserveRatio="true" />
                </VBox>

                <VBox spacing="20" HBox.hgrow="ALWAYS">
                    <Label fx:id="titleLabel" styleClass="heading-large" wrapText="true" />
                    <Separator />

                    <GridPane vgap="12" hgap="25">
                        <Label text="Date:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="input-label" />
                        <Label fx:id="dateLabel" styleClass="event-details" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label text="Lieu:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="input-label" />
                        <Label fx:id="locationLabel" styleClass="event-details" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Type:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="input-label" />
                        <Label fx:id="typeLabel" styleClass="event-details" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    </GridPane>

                    <VBox spacing="8">
                        <Label text="Description:" styleClass="input-label" />
                        <Label fx:id="descriptionLabel" styleClass="card-description" wrapText="true" />
                    </VBox>

                    <Separator />

                    <VBox fx:id="qrCodeContainer" spacing="10" alignment="CENTER" style="-fx-background-color: #F8FAFC; -fx-padding: 15; -fx-background-radius: 15;">
                        <Label text="Scannez pour donner votre avis :" styleClass="input-label" />
                        <ImageView fx:id="qrCodeImageView" fitHeight="160.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true" />
                    </VBox>

                    <HBox spacing="15" alignment="BOTTOM_RIGHT" style="-fx-padding: 10 0 0 0;">
                        <Button fx:id="participateBtn" text="Participer à l'événement" styleClass="btn-primary1" prefHeight="45" prefWidth="250" />
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </content>
</ScrollPane>