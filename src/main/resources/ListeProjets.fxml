<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import java.net.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.ListeProjetsController" styleClass="root-container"
            prefWidth="1200" prefHeight="800">

    <stylesheets>
        <URL value="@styles.css" />
    </stylesheets>

    <left>
        <VBox spacing="10" styleClass="sidebar" prefWidth="250">
            <padding><Insets top="40" right="20" bottom="20" left="20"/></padding>

            <Label text="GESTIONNAIRE" styleClass="sidebar-logo"/>
            <Separator style="-fx-opacity: 0.3; -fx-padding: 10 0;"/>

            <Button text="📊 Tableau de bord" styleClass="sidebar-btn-disabled" />
            <Button text="👥 Employés" styleClass="sidebar-btn-disabled" />

            <Button text="📂 Projets" onAction="#rafraichirDonnees" styleClass="sidebar-btn-active" />

            <Button text="✅ Tâches" styleClass="sidebar-btn-disabled" />
            <Button text="📦 Ressources" styleClass="sidebar-btn-disabled" />
            <Button text="📈 Analyse" styleClass="sidebar-btn-disabled" />

            <Region VBox.vgrow="ALWAYS" />

            <Button text="👤 Mode Employé" onAction="#allerAuFront" styleClass="btn-switch-mode" />
        </VBox>
    </left>

    <center>
        <VBox spacing="25">
            <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

            <Label text="Gestion des Projets" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

            <HBox spacing="15">
                <VBox styleClass="summary-card" HBox.hgrow="ALWAYS" alignment="CENTER" prefHeight="100">
                    <Label fx:id="lblTotal" text="0" styleClass="summary-value"/>
                    <Label text="Total Projets" styleClass="summary-label"/>
                </VBox>
                <VBox styleClass="summary-card" HBox.hgrow="ALWAYS" alignment="CENTER" prefHeight="100">
                    <Label fx:id="lblEnCours" text="0" styleClass="summary-value"/>
                    <Label text="En cours" styleClass="summary-label"/>
                </VBox>
                <VBox styleClass="summary-card" HBox.hgrow="ALWAYS" alignment="CENTER" prefHeight="100">
                    <Label fx:id="lblTermine" text="0" styleClass="summary-value"/>
                    <Label text="Terminés" styleClass="summary-label"/>
                </VBox>
            </HBox>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Rechercher un projet..." styleClass="modern-input" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="comboFiltre" styleClass="modern-input" prefWidth="150"/>
                <Button text="+ Nouveau Projet" onAction="#allerAjouterProjet" styleClass="btn-primary"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="modern-scroll">
                <FlowPane fx:id="containerProjets" hgap="25" vgap="25">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                </FlowPane>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>