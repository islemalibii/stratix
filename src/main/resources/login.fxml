<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<StackPane prefHeight="700.0" prefWidth="1000.0" styleClass="login-root" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LoginController">
   
   <!-- Background with gradient -->
   <HBox prefHeight="700.0" prefWidth="1000.0">
      
      <!-- Left Side: Logo + Feature Cards -->
      <VBox alignment="TOP_CENTER" spacing="60.0" HBox.hgrow="ALWAYS">
         <padding>
            <Insets bottom="60.0" left="80.0" right="80.0" top="80.0" />
         </padding>
         <children>
            <!-- Logo -->
            <ImageView fitHeight="300.0" fitWidth="600.0" preserveRatio="true">
               <image>
                  <Image url="@logo.png" />
               </image>
            </ImageView>
            
            <!-- Feature Cards -->
            <VBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                  <!-- Card 1: Gestion des employés -->
                  <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="feature-card-login">
                     <padding>
                        <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
                     </padding>
                     <children>
                        <StackPane styleClass="feature-icon-box">
                           <Label text="👥" styleClass="feature-icon-emoji" />
                        </StackPane>
                        <VBox spacing="4.0">
                           <Label text="Gestion des employés" styleClass="feature-card-title" />
                           <Label text="Gérez votre équipe efficacement" styleClass="feature-card-desc" />
                        </VBox>
                     </children>
                  </HBox>
                  
                  <!-- Card 2: Suivi des projets -->
                  <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="feature-card-login">
                     <padding>
                        <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
                     </padding>
                     <children>
                        <StackPane styleClass="feature-icon-box">
                           <Label text="📊" styleClass="feature-icon-emoji" />
                        </StackPane>
                        <VBox spacing="4.0">
                           <Label text="Suivi des projets" styleClass="feature-card-title" />
                           <Label text="Suivez vos projets en temps réel" styleClass="feature-card-desc" />
                        </VBox>
                     </children>
                  </HBox>
                  
                  <!-- Card 3: Tableau de bord analytique -->
                  <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="feature-card-login">
                     <padding>
                        <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
                     </padding>
                     <children>
                        <StackPane styleClass="feature-icon-box">
                           <Label text="📈" styleClass="feature-icon-emoji" />
                        </StackPane>
                        <VBox spacing="4.0">
                           <Label text="Tableau de bord analytique" styleClass="feature-card-title" />
                           <Label text="Analysez vos performances" styleClass="feature-card-desc" />
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
      
      <!-- Right Side: Login Form -->
      <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
         <padding>
            <Insets bottom="80.0" left="80.0" right="80.0" top="80.0" />
         </padding>
         <children>
            <!-- White Card Container -->
            <VBox spacing="20.0" styleClass="login-form-card">
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
               <children>
                  <!-- Header -->
                  <VBox alignment="CENTER" spacing="10.0">
                     <Label text="Connexion" styleClass="login-form-title" />
                     <Label text="Accédez à votre espace de gestion" styleClass="login-form-subtitle" />
                  </VBox>
                  
                  <!-- Spacer -->
                  <Region prefHeight="8.0" />
                  
                  <!-- Email Field -->
                  <VBox spacing="10.0">
                     <Label text="Email" styleClass="login-field-label" />
                     <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="login-input-container">
                        <padding>
                           <Insets bottom="14.0" left="16.0" right="16.0" top="14.0" />
                        </padding>
                        <Label text="✉" styleClass="input-icon" />
                        <TextField fx:id="emailField" promptText="" styleClass="login-text-field" HBox.hgrow="ALWAYS" />
                     </HBox>
                  </VBox>
                  
                  <!-- Password Field -->
                  <VBox spacing="10.0">
                     <HBox alignment="CENTER_LEFT">
                        <Label text="Mot de passe" styleClass="login-field-label" HBox.hgrow="ALWAYS" />
                        <Hyperlink text="Oublié ?" styleClass="forgot-password-link" onAction="#handleForgotPassword" />
                     </HBox>
                     <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="login-input-container">
                        <padding>
                           <Insets bottom="14.0" left="16.0" right="16.0" top="14.0" />
                        </padding>
                        <Label text="🔒" styleClass="input-icon" />
                        <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="login-text-field" HBox.hgrow="ALWAYS" />
                     </HBox>
                  </VBox>
                  
                  <!-- Error Label -->
                  <Label fx:id="errorLabel" styleClass="login-error-label" visible="false" wrapText="true" />
                  
                  <!-- Spacer -->
                  <Region prefHeight="4.0" />
                  
                  <!-- Login Button -->
                  <Button fx:id="loginButton" text="Se connecter" styleClass="login-submit-btn" onAction="#handleLogin" maxWidth="Infinity" />
                  
                  <!-- Spacer -->
                  <Region prefHeight="8.0" />
                  
                  <!-- Footer Links -->
                  <HBox alignment="CENTER" spacing="6.0">
                     <Label text="Pas encore de compte ?" styleClass="login-footer-text" />
                     <Hyperlink fx:id="signupLink" text="Créer un compte" styleClass="login-footer-link" onAction="#handleSignup" />
                  </HBox>
                  
                  <!-- Spacer -->
                  <Region prefHeight="12.0" />
                  
                  <!-- Copyright -->
                  <VBox alignment="CENTER">
                     <Label text="© 2026 Stratix - Tous droits réservés" styleClass="login-copyright" />
                  </VBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </HBox>
</StackPane>
