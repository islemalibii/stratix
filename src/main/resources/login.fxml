<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<StackPane prefHeight="700.0" prefWidth="1000.0" styleClass="login-root" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LoginController">

    <GridPane fx:id="mainGrid" alignment="CENTER">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="0.0" percentWidth="55.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="420.0" percentWidth="45.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
        </rowConstraints>

        <children>
            <VBox alignment="CENTER" spacing="50.0" GridPane.columnIndex="0" styleClass="left-panel-content">
                <padding>
                    <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
                </padding>
                <children>
                    <ImageView fitHeight="250.0" fitWidth="500.0" preserveRatio="true">
                        <image>
                            <Image url="@logo.png" />
                        </image>
                    </ImageView>

                    <VBox spacing="20.0" maxWidth="450.0">
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="feature-card-login">
                                <padding><Insets bottom="20.0" left="24.0" right="24.0" top="20.0" /></padding>
                                <StackPane styleClass="feature-icon-box">
                                    <Label text="👥" styleClass="feature-icon-emoji" />
                                </StackPane>
                                <VBox spacing="4.0">
                                    <Label text="Gestion des employés" styleClass="feature-card-title" />
                                    <Label text="Gérez votre équipe efficacement" styleClass="feature-card-desc" />
                                </VBox>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="feature-card-login">
                                <padding><Insets bottom="20.0" left="24.0" right="24.0" top="20.0" /></padding>
                                <StackPane styleClass="feature-icon-box">
                                    <Label text="📊" styleClass="feature-icon-emoji" />
                                </StackPane>
                                <VBox spacing="4.0">
                                    <Label text="Suivi des projets" styleClass="feature-card-title" />
                                    <Label text="Suivez vos projets en temps réel" styleClass="feature-card-desc" />
                                </VBox>
                            </HBox>
                        </children>
                    </VBox>
                </children>
            </VBox>

            <VBox alignment="CENTER" GridPane.columnIndex="1">
                <padding>
                    <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                </padding>
                <children>
                    <VBox spacing="12.0" styleClass="login-form-card" maxWidth="420.0" minWidth="400.0">
                        <padding>
                            <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
                        </padding>
                        <children>
                            <VBox alignment="CENTER" spacing="10.0">
                                <Label text="Connexion" styleClass="login-form-title" />
                                <Label text="Accédez à votre espace de gestion" styleClass="login-form-subtitle" />
                            </VBox>

                            <VBox spacing="8.0">
                                <Label text="Email" styleClass="login-field-label" />
                                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="login-input-container">
                                    <padding><Insets bottom="14.0" left="16.0" right="16.0" top="14.0" /></padding>
                                    <Label text="✉" styleClass="input-icon" />
                                    <TextField fx:id="emailField" styleClass="login-text-field" HBox.hgrow="ALWAYS" />
                                </HBox>
                            </VBox>

                            <VBox spacing="8.0">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Mot de passe" styleClass="login-field-label" HBox.hgrow="ALWAYS" />
                                    <Hyperlink text="Oublié ?" styleClass="forgot-password-link" onAction="#handleForgotPassword" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="login-input-container">
                                    <padding><Insets bottom="14.0" left="16.0" right="16.0" top="14.0" /></padding>
                                    <Label text="🔒" styleClass="input-icon" />
                                    <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="login-text-field" HBox.hgrow="ALWAYS" />
                                </HBox>
                            </VBox>

                            <Label fx:id="errorLabel" styleClass="login-error-label" visible="false" wrapText="true" />
                            <Label fx:id="countdownLabel" styleClass="countdown-label" visible="false" wrapText="true" />

                            <VBox spacing="8.0">
                                <Label text="Vérification de sécurité" styleClass="login-field-label" />
                                <HBox spacing="10.0" alignment="CENTER">
                                    <StackPane fx:id="captchaContainer" styleClass="captcha-container" HBox.hgrow="ALWAYS" minHeight="60.0" />
                                    <Button fx:id="refreshCaptchaButton" text="↻" styleClass="refresh-captcha-btn" onAction="#handleRefreshCaptcha" />
                                </HBox>
                                <TextField fx:id="captchaField" promptText="Entrez le code ci-dessus" styleClass="login-text-field-box" maxWidth="Infinity" />
                            </VBox>

                            <Button fx:id="loginButton" text="Se connecter" styleClass="login-submit-btn" onAction="#handleLogin" maxWidth="Infinity" />

                            <HBox alignment="CENTER" spacing="10.0">
                                <Region HBox.hgrow="ALWAYS" style="-fx-background-color: #E2E8F0; -fx-pref-height: 1;" />
                                <Label text="OU" style="-fx-text-fill: #A0AEC0; -fx-font-size: 12px;" />
                                <Region HBox.hgrow="ALWAYS" style="-fx-background-color: #E2E8F0; -fx-pref-height: 1;" />
                            </HBox>

                            <Button fx:id="googleLoginButton" text="Se connecter avec Google" styleClass="google-login-btn" onAction="#handleGoogleLogin" maxWidth="Infinity" />

                            <HBox alignment="CENTER" spacing="6.0">
                                <Label text="Pas encore de compte ?" styleClass="login-footer-text" />
                                <Hyperlink fx:id="signupLink" text="Créer un compte" styleClass="login-footer-link" onAction="#handleSignup" />
                            </HBox>
                        </children>
                    </VBox>
                </children>
            </VBox>
        </children>
    </GridPane>
</StackPane>