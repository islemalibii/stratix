<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.RessourceController"
            prefHeight="600" prefWidth="900">

    <!-- Menu supérieur -->
    <top>
        <VBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="GESTION DES RESSOURCES" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="← Retour aux Produits" style="-fx-background-color: #3498db; -fx-text-fill: white;" onAction="#retourMenuPrincipal"/>
            </HBox>
        </VBox>
    </top>

    <!-- Centre avec ListView -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <!-- Barre de recherche -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Rechercher:" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                <TextField fx:id="searchField" promptText="Nom, type ou fournisseur..."
                           HBox.hgrow="ALWAYS" prefWidth="250"/>
                <Button fx:id="btnSearch" text="Rechercher"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Button fx:id="btnClearSearch" text="Effacer"
                        style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Boutons d'action avec exports -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Liste des ressources" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>

                <!-- BOUTONS D'EXPORT (NOUVEAUX) -->
                <Button text="📊 Excel" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;"
                        onAction="#exporterRessourcesExcel"/>
                <Button text="📄 PDF" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-cursor: hand;"
                        onAction="#exporterRessourcesPDF"/>

                <!-- Boutons existants -->
                <Button text=" Ajouter" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;"
                        onAction="#ouvrirAjoutRessource"/>
                <Button text=" Modifier" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-cursor: hand;"
                        onAction="#ouvrirModifierRessource"/>
                <Button text="Supprimer" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;"
                        onAction="#supprimerRessource"/>
                <Button text="Rafraîchir" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;"
                        onAction="#rafraichirListe"/>
            </HBox>

            <!-- ListView pour les ressources -->
            <ListView fx:id="listViewRessources" VBox.vgrow="ALWAYS"/>

        </VBox>
    </center>

    <!-- Bas de page avec statistiques -->
    <bottom>
        <HBox spacing="30" style="-fx-background-color: #ecf0f1; -fx-padding: 15;" alignment="CENTER">
            <Label fx:id="statsTotal" text="Total ressources: 0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label fx:id="statsQuantiteTotale" text="Quantité totale: 0" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
            <Label fx:id="statsTypes" text="Types: 0" style="-fx-font-weight: bold; -fx-text-fill: #3498db;"/>
        </HBox>
    </bottom>
</BorderPane>