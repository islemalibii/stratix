<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.RessourceController"
            prefHeight="600" prefWidth="900">

    <!-- Menu supérieur -->
    <top>
        <VBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="GESTION DES RESSOURCES" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="← Retour aux Produits" style="-fx-background-color: #3498db; -fx-text-fill: white;" onAction="#retourMenuPrincipal"/>
            </HBox>
        </VBox>
    </top>

    <!-- Centre avec TableView -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Liste des ressources" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="➕ Ajouter" style="-fx-background-color: #27ae60; -fx-text-fill: white;" onAction="#ouvrirAjoutRessource"/>
                <Button text="✏️ Modifier" style="-fx-background-color: #f39c12; -fx-text-fill: white;" onAction="#ouvrirModifierRessource"/>
                <Button text="🗑️ Supprimer" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" onAction="#supprimerRessource"/>
                <Button text="🔄 Rafraîchir" style="-fx-background-color: #3498db; -fx-text-fill: white;" onAction="#rafraichirListe"/>
            </HBox>

            <TableView fx:id="tableViewRessources" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="200"/>
                    <TableColumn fx:id="colType" text="Type" prefWidth="150"/>
                    <TableColumn fx:id="colQuantite" text="Quantité" prefWidth="100"/>
                    <TableColumn fx:id="colFournisseur" text="Fournisseur" prefWidth="200"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <!-- Bas de page avec statistiques -->
    <bottom>
        <HBox spacing="30" style="-fx-background-color: #ecf0f1; -fx-padding: 15;" alignment="CENTER">
            <Label fx:id="statsTotal" text="Total ressources: 0" style="-fx-font-weight: bold;"/>
            <Label fx:id="statsQuantiteTotale" text="Quantité totale: 0" style="-fx-font-weight: bold;"/>
            <Label fx:id="statsTypes" text="Types: 0" style="-fx-font-weight: bold;"/>
        </HBox>
    </bottom>
</BorderPane>