<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.RessourceController"
            prefHeight="600" prefWidth="1000">

    <!-- Centre avec ListView -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <!-- Barre de recherche -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Rechercher:" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                <TextField fx:id="searchField" promptText="Nom, type ou fournisseur..."
                           HBox.hgrow="ALWAYS" prefWidth="250"/>
                <Button fx:id="btnSearch" text="Rechercher"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Button fx:id="btnClearSearch" text="Effacer"
                        style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Bouton Nouvelle Ressource -->
                <Button text="➕ Nouvelle Ressource"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 15;"
                        onAction="#ouvrirAjoutRessource"/>
            </HBox>

            <!-- Titre -->
            <Label text="Gestion des Ressources"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-padding: 0 0 10 0;"/>

            <!-- ListView pour les ressources -->
            <ListView fx:id="listViewRessources" VBox.vgrow="ALWAYS"/>

            <!-- Statistiques -->
            <HBox spacing="30" style="-fx-background-color: #ecf0f1; -fx-padding: 15;" alignment="CENTER">
                <Label fx:id="statsTotal" text="Total ressources: 0"
                       style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Label fx:id="statsQuantiteTotale" text="Quantité totale: 0"
                       style="-fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                <Label fx:id="statsTypes" text="Types: 0"
                       style="-fx-font-weight: bold; -fx-text-fill: #3498db;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>