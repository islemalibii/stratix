<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="700.0" prefWidth="1100.0" spacing="25" styleClass="main-bg"
      stylesheets="@/style/global.css" xmlns="http://javafx.com/javafx/20"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.EventDashboardController">

    <HBox alignment="CENTER" spacing="20">
        <VBox alignment="CENTER" prefHeight="100.0" prefWidth="180.0" styleClass="stat-card">
            <Label text="Total Événements" styleClass="stat-label" />
            <Label fx:id="totalLabel" text="0" styleClass="stat-value" />
        </VBox>

        <VBox alignment="CENTER" prefHeight="100.0" prefWidth="180.0" styleClass="stat-card">
            <Label text="Planifiés" styleClass="stat-label, stat-planned" />
            <Label fx:id="plannedLabel" text="0" styleClass="stat-value, stat-planned" />
        </VBox>

        <VBox alignment="CENTER" prefHeight="100.0" prefWidth="180.0" styleClass="stat-card">
            <Label text="Terminés" styleClass="stat-label, stat-finished" />
            <Label fx:id="finishedLabel" text="0" styleClass="stat-value, stat-finished" />
        </VBox>

        <VBox alignment="CENTER" prefHeight="100.0" prefWidth="180.0" styleClass="stat-card">
            <Label text="Annulés" styleClass="stat-label, stat-cancelled" />
            <Label fx:id="cancelledLabel" text="0" styleClass="stat-value, stat-cancelled" />
        </VBox>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 0 20 0 20;">
        <TextField fx:id="searchField" onKeyReleased="#search"
                   promptText="🔍 Rechercher par titre..."
                   styleClass="search-field" HBox.hgrow="ALWAYS" />
        <Button fx:id="addBtn" onAction="#goToAddEvent" text="Ajouter" styleClass="btn-primary" />
        <Button fx:id="archivedBtn" onAction="#goToArchived" text="Archives" styleClass="btn-secondary" />
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="custom-scroll-pane" VBox.vgrow="ALWAYS">
        <content>
            <FlowPane fx:id="eventContainer" hgap="25.0" vgap="25.0" prefWrapLength="1000.0">
                <padding>
                    <Insets bottom="30.0" left="30.0" right="30.0" top="10.0" />
                </padding>
            </FlowPane>
        </content>
    </ScrollPane>

</VBox>