<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="750.0" prefWidth="1300.0" styleClass="main-bg"
            stylesheets="@/style/global.css" xmlns="http://javafx.com/javafx/20"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.EventDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="90.0" spacing="20.0" styleClass="dashboard-top-bar-light">
            <padding>
                <Insets bottom="10.0" left="25.0" right="25.0" top="10.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <ImageView fitHeight="70.0" fitWidth="220.0" preserveRatio="true">
                        <image>
                            <Image url="@/images/logo.png" />
                        </image>
                    </ImageView>
                    <Label text="Strati X" styleClass="sidebar-brand" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <Label fx:id="welcomeLabel" text="Bienvenue," />
                    <StackPane>
                        <Circle radius="22.0" styleClass="avatar-circle" />
                        <Label fx:id="avatarLabel" text="A" />
                    </StackPane>
                    <Button fx:id="logoutButton" onAction="#handleLogout"
                            styleClass="logout-button-modern" text="Déconnexion" />
                </HBox>
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="260.0" spacing="8.0" styleClass="sidebar">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
            </padding>
            <children>
                <Label text="MENU PRINCIPAL" textFill="#A0AEC0" style="-fx-font-weight: bold; -fx-font-size: 11;">
                    <VBox.margin>
                        <Insets bottom="10.0" left="10.0" />
                    </VBox.margin>
                </Label>

                <Button text="Tableau de bord" styleClass="sidebar-btn" maxWidth="Infinity" alignment="BASELINE_LEFT" />
                <Button text="Employés" styleClass="sidebar-btn" maxWidth="Infinity" alignment="BASELINE_LEFT" />
                <Button text="Projets" styleClass="sidebar-btn" maxWidth="Infinity" alignment="BASELINE_LEFT" />
                <Button text="Tâches et planning" styleClass="sidebar-btn" maxWidth="Infinity" alignment="BASELINE_LEFT" />

                <Button fx:id="btnEvenements" text="Événements" onAction="#handleEvenements"
                        styleClass="sidebar-btn, sidebar-btn-active" maxWidth="Infinity" alignment="BASELINE_LEFT" />

                <Button text="Produits et ressources" styleClass="sidebar-btn" maxWidth="Infinity" alignment="BASELINE_LEFT" />
                <Button text="Services" styleClass="sidebar-btn" maxWidth="Infinity" alignment="BASELINE_LEFT" />

                <Region VBox.vgrow="ALWAYS" />

            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="25">
            <padding>
                <Insets top="25" right="30" bottom="25" left="30"/>
            </padding>

            <HBox alignment="CENTER" spacing="20">
                <VBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" styleClass="stat-card">
                    <Label text="Total Événements" styleClass="stat-label" />
                    <Label fx:id="totalLabel" text="0" styleClass="stat-value" />
                </VBox>
                <VBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" styleClass="stat-card">
                    <Label text="Planifiés" styleClass="stat-label, stat-planned" />
                    <Label fx:id="plannedLabel" text="0" styleClass="stat-value, stat-planned" />
                </VBox>
                <VBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" styleClass="stat-card">
                    <Label text="Terminés" styleClass="stat-label, stat-finished" />
                    <Label fx:id="finishedLabel" text="0" styleClass="stat-value, stat-finished" />
                </VBox>
                <VBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" styleClass="stat-card">
                    <Label text="Annulés" styleClass="stat-label, stat-cancelled" />
                    <Label fx:id="cancelledLabel" text="0" styleClass="stat-value, stat-cancelled" />
                </VBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="15">
                <TextField fx:id="searchField" onKeyReleased="#search"
                           promptText="Rechercher un événement..."
                           HBox.hgrow="ALWAYS" styleClass="text-field"/>
                <ComboBox fx:id="filterStatusCombo" onAction="#handleFilter"
                          promptText="Filtrer" prefWidth="180"/>
                <Button onAction="#goToAddEvent" text="Ajouter" styleClass="btn-primary" />
                <Button onAction="#goToArchived" text="Archives" styleClass="btn-secondary" />
                <Button text="Synchroniser" onAction="#syncWithGoogle" styleClass="btn-secondary" />
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                <content>
                    <FlowPane fx:id="eventContainer" hgap="25.0" vgap="25.0">
                        <padding>
                            <Insets bottom="30.0" left="10.0" right="10.0" top="10.0" />
                        </padding>
                    </FlowPane>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>