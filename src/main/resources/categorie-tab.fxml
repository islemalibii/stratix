<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" styleClass="main-container" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.CategorieController">
    <Label text="GESTION DES CATÉGORIES" styleClass="page-title"/>
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Liste des Catégories" styleClass="section-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnArchives" text=" Archives" onAction="#handleVoirArchives" styleClass="btn-archive"/>
        <Button fx:id="btnRetour" text="⬅ Retour" onAction="#handleRetour" styleClass="btn-retour" visible="false"/>
        <Button text="+ Ajouter" onAction="#handleAjouter" styleClass="btn-add"/>
    </HBox>
    <GridPane styleClass="table-header" hgap="10" vgap="5">
        <columnConstraints>
            <ColumnConstraints percentWidth="40"/>
            <ColumnConstraints percentWidth="40"/>
            <ColumnConstraints percentWidth="20"/>
        </columnConstraints>
        <Label text="Nom" styleClass="table-header-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label text="Description" styleClass="table-header-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Actions" styleClass="table-header-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
    </GridPane>
    <ScrollPane fitToWidth="true" styleClass="table-scroll" VBox.vgrow="ALWAYS">
        <VBox fx:id="categoriesContainer" spacing="1" styleClass="table-body"/>
    </ScrollPane>
</VBox>