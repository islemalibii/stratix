<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" styleClass="modern-container" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.CategorieController">

    <Label text="GESTION DES CATÉGORIES" styleClass="modern-title"/>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button fx:id="btnArchives" text="📦 Archives" onAction="#handleVoirArchives" styleClass="modern-button-archive"/>
        <Button fx:id="btnRetour" text="⬅ Retour" onAction="#handleRetour" styleClass="modern-button-retour" visible="false"/>
        <Button text="+ Nouvelle catégorie" onAction="#handleAjouter" styleClass="modern-button-add"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="modern-scroll">
        <GridPane fx:id="categoriesGrid" hgap="20" vgap="20" styleClass="cards-grid">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
        </GridPane>
    </ScrollPane>

</VBox>