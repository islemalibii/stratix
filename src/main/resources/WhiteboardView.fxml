<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.WhiteboardController"
            style="-fx-background-color: #f8fafc;">

    <top>
        <VBox spacing="0">
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 15 30 10 30; -fx-background-color: #f8fafc;">
                <Button onAction="#showDashboardFromButton" text="🏠 Dashboard"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showPlanningFromButton" text="📅 Planning"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showTachesFromButton" text="📋 Tâches"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showCalendarFromButton" text="📆 Calendrier"
                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showWhiteboardFromButton" text="📋 Whiteboard"
                        style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>

            <VBox style="-fx-background-color: #2c3e50; -fx-padding: 20 30;">
                <Label text="📋 TABLEAU KANBAN"
                       style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Label text="Glissez-déposez ou utilisez le clic droit pour gérer vos tâches"
                       style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
            </VBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="20" style="-fx-padding: 20;">
            <VBox spacing="10" style="-fx-background-color: #f1f5f9; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📌" style="-fx-font-size: 20px;"/>
                    <Label text="À FAIRE" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <Label fx:id="lblCountAFaire" text="0"
                           style="-fx-background-color: #94a3b8; -fx-text-fill: white; -fx-padding: 2 8; -fx-background-radius: 12;"/>
                </HBox>
                <Separator style="-fx-background-color: #cbd5e1;"/>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="columnAFaire" spacing="10" prefWidth="280"/>
                </ScrollPane>
            </VBox>

            <VBox spacing="10" style="-fx-background-color: #fef9c3; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="⚡" style="-fx-font-size: 20px;"/>
                    <Label text="EN COURS" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #854d0e;"/>
                    <Label fx:id="lblCountEnCours" text="0"
                           style="-fx-background-color: #eab308; -fx-text-fill: white; -fx-padding: 2 8; -fx-background-radius: 12;"/>
                </HBox>
                <Separator style="-fx-background-color: #fde047;"/>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="columnEnCours" spacing="10" prefWidth="280"/>
                </ScrollPane>
            </VBox>

            <VBox spacing="10" style="-fx-background-color: #dcfce7; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="✅" style="-fx-font-size: 20px;"/>
                    <Label text="TERMINÉE" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #166534;"/>
                    <Label fx:id="lblCountTerminee" text="0"
                           style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-padding: 2 8; -fx-background-radius: 12;"/>
                </HBox>
                <Separator style="-fx-background-color: #86efac;"/>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="columnTerminee" spacing="10" prefWidth="280"/>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>
</BorderPane>