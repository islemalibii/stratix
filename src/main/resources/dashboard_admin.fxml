<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>

<StackPane prefHeight="700.0" prefWidth="1200.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.DashboardAdminController">
   
   <!-- Main Content -->
   <BorderPane styleClass="dashboard-root">
   
   <!-- Top Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="90.0" spacing="20.0" styleClass="dashboard-top-bar-light">
            <padding>
                <Insets bottom="10.0" left="25.0" right="25.0" top="10.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <ImageView fitHeight="70.0" fitWidth="220.0" preserveRatio="true">
                        <image>
                            <Image url="@/images/logo.png" />
                        </image>
                    </ImageView>
                    <Label text="Strati X" styleClass="sidebar-brand" />
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <HBox fx:id="userProfileSection" alignment="CENTER" spacing="10.0" onMouseClicked="#handleProfileClick" styleClass="user-profile-section">
                        <Label fx:id="welcomeLabel" text="Bienvenue, Admin" textFill="#2D3748">
                            <font>
                                <Font name="System Bold" size="15.0" />
                            </font>
                        </Label>
                        <StackPane>
                            <Circle radius="22.0" fill="#EDF2F7" />
                            <Label fx:id="avatarLabel" text="A" textFill="#3182CE">
                                <font>
                                    <Font name="System Bold" size="16.0" />
                                </font>
                            </Label>
                        </StackPane>
                    </HBox>
                    <Button fx:id="logoutButton" mnemonicParsing="false" onAction="#handleLogout" styleClass="logout-button-modern" text="Déconnexion" />
                </HBox>
            </children>
        </HBox>
    </top>
   
   <!-- Left Sidebar -->
    <left>
        <VBox prefWidth="260.0" spacing="8.0" styleClass="sidebar">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
            </padding>
            <children>
                <Label text="MENU PRINCIPAL" textFill="#A0AEC0">
                    <font>
                        <Font name="System Bold" size="11.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" left="10.0" top="5.0" />
                    </VBox.margin>
                </Label>

                <Button fx:id="btnUtilisateurs" mnemonicParsing="false" onAction="#showUtilisateurs"
                        styleClass="sidebar-btn, sidebar-btn-active" text="👥  Utilisateurs" maxWidth="Infinity" />

                <Button fx:id="btnEmployes" mnemonicParsing="false" onAction="#showEmployes"
                        styleClass="sidebar-btn" text="💼  Employés" maxWidth="Infinity" />

                <Button fx:id="btnAdmins" mnemonicParsing="false" onAction="#showAdmins"
                        styleClass="sidebar-btn" text="🔐  Admins" maxWidth="Infinity" />

                <Button fx:id="btnCEOs" mnemonicParsing="false" onAction="#showCEOs"
                        styleClass="sidebar-btn" text="⭐  CEOs" maxWidth="Infinity" />

                <Button fx:id="btnResponsables" mnemonicParsing="false" onAction="#showResponsables"
                        styleClass="sidebar-btn" text="👔  Responsables" maxWidth="Infinity" />

                <Button fx:id="btnEvenements" mnemonicParsing="false" onAction="#handleEvenements"
                        styleClass="side-btn-dark" text="📅  Événements" maxWidth="Infinity" />

                <Region VBox.vgrow="ALWAYS" />

                <VBox spacing="10.0" styleClass="tip-box-light">
                    <children>
                        <Label text="💡 Astuce" textFill="#2D3748">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <Label text="Utilisez la recherche pour trouver rapidement un utilisateur" textFill="#718096" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>
   
   <!-- Center Content -->
   <center>
      <VBox spacing="20.0" styleClass="dashboard-content">
         <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
         </padding>
         <children>
            <!-- Header Section -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                     <Label fx:id="titleLabel" text="Gestion des Utilisateurs" textFill="#1A1F36">
                        <font>
                           <Font name="System Bold" size="24.0" />
                        </font>
                     </Label>
                     <Label text="Gérez et organisez vos utilisateurs" textFill="#8F9BB3">
                        <font>
                           <Font size="13.0" />
                        </font>
                     </Label>
                  </VBox>
                  <Button fx:id="btnAjouter" mnemonicParsing="false" onAction="#handleAjouter" styleClass="add-button" text="+ Ajouter">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            
            <!-- Search Bar -->
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="search-bar">
               <children>
                  <Label text="🔍" textFill="#8F9BB3">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
                  <TextField fx:id="searchField" promptText="Rechercher par nom, prénom ou email..." styleClass="login-text-field" HBox.hgrow="ALWAYS">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </TextField>
                  <Button fx:id="btnSearch" mnemonicParsing="false" onAction="#handleSearch" styleClass="search-button" text="Rechercher">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            
            <!-- Cards Container -->
            <ScrollPane fitToWidth="true" prefHeight="500.0" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="cardsContainer" spacing="15.0">
                     <padding>
                        <Insets bottom="10.0" left="5.0" right="5.0" top="5.0" />
                     </padding>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </center>
   </BorderPane>
   
   <!-- Chatbot Overlay -->
   <VBox fx:id="chatbotContainer" styleClass="chatbot-container" managed="false" visible="false" 
         maxWidth="400" maxHeight="500" StackPane.alignment="BOTTOM_RIGHT" mouseTransparent="false">
      <padding>
         <Insets bottom="90.0" right="30.0" />
      </padding>
      <!-- Chat Window -->
      <VBox styleClass="chat-window" spacing="10" mouseTransparent="false">
         <padding>
            <Insets top="15.0" bottom="15.0" left="15.0" right="15.0" />
         </padding>
         <children>
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="10">
               <Label text="🤖 Assistant Admin" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
               <Region HBox.hgrow="ALWAYS" />
               <Button text="✕" onAction="#closeChatbot" style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-cursor: hand;" />
            </HBox>
            
            <Separator />
            
            <!-- Messages Area -->
            <ScrollPane fx:id="chatScrollPane" fitToWidth="true" prefHeight="300" style="-fx-background-color: #f5f5f5; -fx-background: #f5f5f5;">
               <VBox fx:id="chatMessagesContainer" spacing="10" style="-fx-background-color: #f5f5f5;">
                  <padding>
                     <Insets top="10.0" bottom="10.0" left="10.0" right="10.0" />
                  </padding>
               </VBox>
            </ScrollPane>
            
            <!-- Input Area -->
            <HBox spacing="10" alignment="CENTER">
               <TextField fx:id="chatInputField" promptText="Posez votre question..." HBox.hgrow="ALWAYS" onAction="#sendChatMessage" />
               <Button text="Envoyer" onAction="#sendChatMessage" styleClass="button-primary" />
            </HBox>
         </children>
      </VBox>
   </VBox>
   
   <!-- Floating Chat Button -->
   <Button fx:id="chatbotButton" text="💬" onAction="#toggleChatbot" styleClass="chatbot-fab" 
           StackPane.alignment="BOTTOM_RIGHT" mouseTransparent="false">
      <StackPane.margin>
         <Insets bottom="30.0" right="30.0" />
      </StackPane.margin>
   </Button>
   
</StackPane>
