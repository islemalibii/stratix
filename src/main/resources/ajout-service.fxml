<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" styleClass="popup-container" prefWidth="500" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AjoutController">

    <Label fx:id="lblTitrePopup" text="AJOUTER UN SERVICE" styleClass="popup-title"/>

    <Label fx:id="lblError" style="-fx-text-fill: red; -fx-wrap-text: true;" managed="true"/>

    <GridPane hgap="15" vgap="12" styleClass="form-grid">
        <Label text="Titre:" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtTitre" styleClass="form-field" promptText="Nom du service" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Catégorie:" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboCategorie" styleClass="form-field" promptText="Sélectionner une catégorie" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Description:" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextArea fx:id="txtDescription" prefRowCount="3" styleClass="form-field" promptText="Description du service" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Date création:" styleClass="form-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dateCreationPicker" styleClass="form-field" GridPane.rowIndex="3" GridPane.columnIndex="1" editable="false" disable="true"/>

        <Label text="Date début:" styleClass="form-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dateDebutPicker" styleClass="form-field" promptText="AAAA-MM-JJ" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Date fin:" styleClass="form-label" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dateFinPicker" styleClass="form-field" promptText="AAAA-MM-JJ" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Responsable:" styleClass="form-label" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboResponsable" styleClass="form-field" promptText="Sélectionner un responsable" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

        <Label text="Budget (DT):" styleClass="form-label" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
        <TextField fx:id="txtBudget" styleClass="form-field" promptText="5000" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" styleClass="popup-buttons">
        <Button fx:id="btnAction" text="Ajouter" onAction="#handleAjouter" styleClass="btn-success"/>
        <Button text="Fermer" onAction="#handleFermer" styleClass="btn-gray"/>
    </HBox>

</VBox>