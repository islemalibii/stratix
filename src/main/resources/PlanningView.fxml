<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="700" prefWidth="1000" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PlanningController">

    <top>
        <VBox spacing="0">
            <!-- Barre de navigation -->
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 15 30 10 30; -fx-background-color: #f8fafc;">
                <Button onAction="#showDashboardFromButton" text="🏠 Dashboard"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showPlanningFromButton" text="📅 Planning"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showTachesFromButton" text="📋 Tâches"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showCalendarFromButton" text="📆 Calendrier"
                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showWhiteboardFromButton" text="📋 Whiteboard"
                        style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>

            <!-- En-tête avec titre et statistiques -->
            <HBox alignment="CENTER_LEFT" prefHeight="70" spacing="15" style="-fx-background-color: linear-gradient(to right, #1e293b, #0f172a); -fx-padding: 0 30;">
                <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="📅 GESTION DES PLANNINGS" />
                <Circle radius="6" fill="#4ade80"/>
                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;" text="Ajouter / Modifier un planning"/>
                <Region HBox.hgrow="ALWAYS" />

                <!-- Statistiques compactes -->
                <HBox spacing="15">
                    <VBox alignment="CENTER">
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10px;" text="Employés" />
                        <Label fx:id="lblTotalEmployes" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" text="26" />
                    </VBox>
                    <VBox alignment="CENTER">
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10px;" text="En poste" />
                        <Label fx:id="lblEnPoste" style="-fx-text-fill: #4ade80; -fx-font-size: 16px; -fx-font-weight: bold;" text="25" />
                    </VBox>
                    <VBox alignment="CENTER">
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10px;" text="Absents" />
                        <Label fx:id="lblAbsents" style="-fx-text-fill: #ef4444; -fx-font-size: 16px; -fx-font-weight: bold;" text="1" />
                    </VBox>
                </HBox>

                <!-- Bouton pour voir la liste -->
                <Button onAction="#openPlanningListe" text="📋 Voir la liste"
                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 6 15; -fx-background-radius: 20; -fx-cursor: hand; -fx-margin-left: 10;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 25;">

                <!-- Boutons rapides Congé/Maladie/Formation -->
                <HBox spacing="10">
                    <Button onAction="#demandeConge" text="+ Congé"
                            style="-fx-background-color: #1cc88a; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
                    <Button onAction="#demandeMaladie" text="+ Maladie"
                            style="-fx-background-color: #e74a3b; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
                    <Button onAction="#demandeFormation" text="+ Formation"
                            style="-fx-background-color: #36b9cc; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;" text="* Champs obligatoires"/>
                </HBox>

                <!-- Formulaire principal -->
                <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 0);">

                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="➕ AJOUTER / MODIFIER UN PLANNING" />

                    <Separator style="-fx-background-color: #e2e8f0;" />

                    <!-- Ligne 1: Employé et Date -->
                    <HBox spacing="15">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #475569;" text="Employé *" />
                            <ComboBox fx:id="cmbEmploye" prefHeight="40" promptText="Sélectionner un employé"
                                      style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1; -fx-padding: 5;" />
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #475569;" text="Date *" />
                            <DatePicker fx:id="dpDate" prefHeight="40" promptText="Sélectionner une date"
                                        style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1;" />
                        </VBox>
                    </HBox>

                    <!-- Ligne 2: Heure début et Heure fin -->
                    <HBox spacing="15">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #475569;" text="Heure début *" />
                            <TextField fx:id="txtHeureDebut" promptText="HH:MM"
                                       style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1; -fx-padding: 10;" />
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #475569;" text="Heure fin *" />
                            <TextField fx:id="txtHeureFin" promptText="HH:MM"
                                       style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1; -fx-padding: 10;" />
                        </VBox>
                    </HBox>

                    <!-- Ligne 3: Type de shift -->
                    <VBox spacing="5">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #475569;" text="Type de shift *" />
                        <ComboBox fx:id="cbTypeShift" prefHeight="40" promptText="Sélectionner un type"
                                  style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1; -fx-padding: 5;" />
                    </VBox>

                    <Separator style="-fx-background-color: #e2e8f0;" />

                    <!-- Boutons d'action -->
                    <HBox alignment="CENTER" spacing="15">
                        <Button onAction="#ajouterPlanning" prefWidth="120"
                                style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.2), 5, 0, 0, 0);"
                                text="➕ Ajouter" />
                        <Button onAction="#modifierPlanning" prefWidth="120"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(245,158,11,0.2), 5, 0, 0, 0);"
                                text="✏️ Modifier" />
                        <Button onAction="#supprimerPlanning" prefWidth="120"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(239,68,68,0.2), 5, 0, 0, 0);"
                                text="🗑️ Supprimer" />
                    </HBox>

                    <!-- Message de confirmation -->
                    <Label fx:id="lblMessage" style="-fx-text-fill: #10b981; -fx-font-size: 13px; -fx-alignment: center;" />
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>