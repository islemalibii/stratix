<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="725.0" prefWidth="974.0" style="-fx-background-color: #f0f4f8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PlanningController">

    <!-- Header -->
    <VBox layoutX="0" layoutY="0" prefWidth="1000" style="-fx-background-color: #2c3e50;">
        <HBox alignment="CENTER_LEFT" prefHeight="70" spacing="20" style="-fx-padding: 0 30;">
            <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="📅 GESTION DU PLANNING" />

            <!-- Bouton pour voir la liste -->
            <Button onAction="#openPlanningList" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 20; -fx-background-radius: 8; -fx-cursor: hand;" text="📋 Voir la liste des plannings" />
        </HBox>
    </VBox>

    <!-- Statistiques -->
    <HBox layoutX="30" layoutY="90" prefWidth="940" spacing="20">
        <!-- Total Employés -->
        <VBox spacing="5" style="-fx-background-color: #B3EBF2; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 14px; -fx-text-fill: #1e40af;" text="Employés total" />
            <Label fx:id="lblTotalEmployes" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1e40af;" text="0" />
        </VBox>

        <!-- En poste -->
        <VBox spacing="5" style="-fx-background-color: #f0fdf4; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 14px; -fx-text-fill: #166534;" text="En poste" />
            <Label fx:id="lblEnPoste" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #166534;" text="0" />
        </VBox>

        <!-- Absents -->
        <VBox spacing="5" style="-fx-background-color: #fef2f2; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 14px; -fx-text-fill: #991b1b;" text="Absents" />
            <Label fx:id="lblAbsents" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #991b1b;" text="0" />
        </VBox>
    </HBox>

    <!-- Titre section -->
    <Label layoutX="254.0" layoutY="213.0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="➕ AJOUTER UN PLANNING" />

    <!-- Formulaire -->
    <VBox layoutX="230.0" layoutY="252.0" prefHeight="451.0" prefWidth="590.0" spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">

        <!-- Boutons rapides pour les congés -->
        <HBox alignment="CENTER" spacing="10">
            <Button onAction="#demandeConge" style="-fx-background-color: #fbbf24; -fx-text-fill: #92400e; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 8; -fx-cursor: hand;" text="➕ Congé" />
            <Button onAction="#demandeMaladie" style="-fx-background-color: #f87171; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 8; -fx-cursor: hand;" text="🏥 Maladie" />
            <Button onAction="#demandeFormation" style="-fx-background-color: #60a5fa; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 8; -fx-cursor: hand;" text="📚 Formation" />
        </HBox>

        <!-- Employé -->
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #475569;" text="Employé *" />
            <ComboBox fx:id="cmbEmploye" prefHeight="40" promptText="Sélectionner un employé" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1;" />
        </VBox>

        <!-- Date -->
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #475569;" text="Date *" />
            <DatePicker fx:id="dpDate" prefHeight="40" promptText="Sélectionner une date" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1;" />
        </VBox>

        <!-- Heures -->
        <HBox spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #475569;" text="Heure début *" />
                <TextField fx:id="txtHeureDebut" prefHeight="40" promptText="HH:MM" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1; -fx-padding: 10;" />
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #475569;" text="Heure fin *" />
                <TextField fx:id="txtHeureFin" prefHeight="40" promptText="HH:MM" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1; -fx-padding: 10;" />
            </VBox>
        </HBox>

        <!-- Type de shift -->
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #475569;" text="Type de shift *" />
            <ComboBox fx:id="cbTypeShift" prefHeight="40" promptText="Sélectionner un type" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1;" />
        </VBox>

        <!-- Boutons -->
        <HBox alignment="CENTER" prefHeight="60" spacing="20">
            <Button onAction="#ajouterPlanning" prefWidth="120" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 8; -fx-cursor: hand;" text="✅ Ajouter" />
            <Button onAction="#modifierPlanning" prefHeight="44.0" prefWidth="142.0" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 8; -fx-cursor: hand;" text="✏️ Modifier" />
            <Button onAction="#supprimerPlanning" prefHeight="44.0" prefWidth="141.0" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 8; -fx-cursor: hand;" text="🗑️ Supprimer" />
        </HBox>

        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;" text="* Champs obligatoires" />
    </VBox>
</AnchorPane>
