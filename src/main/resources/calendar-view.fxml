<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800" prefWidth="1200" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.WhiteboardController">

    <!-- Header -->
    <HBox layoutX="0" layoutY="0" prefHeight="70" prefWidth="1200" style="-fx-background-color: #1e293b; -fx-padding: 0 20;" alignment="CENTER_LEFT">
        <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="📋 TABLEAU KANBAN - GESTION DES TÂCHES" />
    </HBox>

    <!-- Instructions -->
    <HBox layoutX="20" layoutY="90" spacing="10" alignment="CENTER_LEFT">
        <Label style="-fx-font-size: 14px; -fx-text-fill: #6b7280;" text="💡 Cliquez droit sur une carte pour plus d'options" />
    </HBox>

    <!-- Kanban Board -->
    <HBox layoutX="20" layoutY="120" spacing="20" prefHeight="650">

        <!-- Colonne À FAIRE -->
        <VBox spacing="10" prefWidth="280" style="-fx-background-color: #f1f5f9; -fx-padding: 15; -fx-background-radius: 10;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #475569;" text="📌 À FAIRE" />
                <Label fx:id="lblCountAFaire" style="-fx-background-color: #94a3b8; -fx-text-fill: white; -fx-padding: 2 8; -fx-background-radius: 12;" text="0" />
            </HBox>

            <ScrollPane fitToWidth="true" prefHeight="550" style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox fx:id="columnAFaire" spacing="10" prefWidth="250">
                    <!-- Les cartes seront ajoutées dynamiquement -->
                </VBox>
            </ScrollPane>
        </VBox>

        <!-- Colonne EN COURS -->
        <VBox spacing="10" prefWidth="280" style="-fx-background-color: #fef9c3; -fx-padding: 15; -fx-background-radius: 10;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #854d0e;" text="⚡ EN COURS" />
                <Label fx:id="lblCountEnCours" style="-fx-background-color: #eab308; -fx-text-fill: white; -fx-padding: 2 8; -fx-background-radius: 12;" text="0" />
            </HBox>

            <ScrollPane fitToWidth="true" prefHeight="550" style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox fx:id="columnEnCours" spacing="10" prefWidth="250">
                    <!-- Les cartes seront ajoutées dynamiquement -->
                </VBox>
            </ScrollPane>
        </VBox>

        <!-- Colonne TERMINÉE -->
        <VBox spacing="10" prefWidth="280" style="-fx-background-color: #dcfce7; -fx-padding: 15; -fx-background-radius: 10;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #166534;" text="✅ TERMINÉE" />
                <Label fx:id="lblCountTerminee" style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-padding: 2 8; -fx-background-radius: 12;" text="0" />
            </HBox>

            <ScrollPane fitToWidth="true" prefHeight="550" style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox fx:id="columnTerminee" spacing="10" prefWidth="250">
                    <!-- Les cartes seront ajoutées dynamiquement -->
                </VBox>
            </ScrollPane>
        </VBox>

    </HBox>

</AnchorPane>