<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.CalendarController"
            style="-fx-background-color: #f8fafc;">

    <!-- Header -->
    <top>
        <VBox spacing="0">
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 15 30 10 30; -fx-background-color: #f8fafc;">
                <Button onAction="#showDashboardFromButton" text="🏠 Dashboard"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showPlanningFromButton" text="📅 Planning"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showTachesFromButton" text="📋 Tâches"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showCalendarFromButton" text="📆 Calendrier"
                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showWhiteboardFromButton" text="📋 Whiteboard"
                        style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>

            <VBox style="-fx-background-color: linear-gradient(to right, #1e293b, #0f172a); -fx-padding: 20 30;">
                <Label text="📅 "
                       style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Label text="Visualisation mensuelle des plannings employés"
                       style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
            </VBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 20;">

            <!-- Navigation mois -->
            <HBox spacing="20" alignment="CENTER">
                <Button text="◀ Mois précédent" onAction="#previousMonth"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
                <Label fx:id="lblMonthYear" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Février 2026"/>
                <Button text="Mois suivant ▶" onAction="#nextMonth"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>

            <!-- Calendrier -->
            <HBox spacing="20">
                <!-- Grille du calendrier -->
                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Calendrier" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <ScrollPane fitToWidth="true" style="-fx-background: white; -fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 10;">
                        <GridPane fx:id="calendarGrid" hgap="5" vgap="5" style="-fx-padding: 10;">
                            <!-- Le contenu sera rempli par le contrôleur -->
                        </GridPane>
                    </ScrollPane>
                </VBox>

                <!-- Liste des événements du jour -->
                <VBox spacing="10" prefWidth="300">
                    <Label text="Événements du jour" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <ListView fx:id="eventsListView" prefHeight="400" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;"/>
                </VBox>
            </HBox>

            <!-- Légende -->
            <HBox spacing="30" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #e2e8f0;">
                <Label text="Légende :" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <HBox spacing="5">
                    <Label text="●" style="-fx-text-fill: #3b82f6; -fx-font-size: 16px;"/>
                    <Label text="Matin"/>
                </HBox>
                <HBox spacing="5">
                    <Label text="●" style="-fx-text-fill: #f59e0b; -fx-font-size: 16px;"/>
                    <Label text="Après-midi"/>
                </HBox>
                <HBox spacing="5">
                    <Label text="●" style="-fx-text-fill: #8b5cf6; -fx-font-size: 16px;"/>
                    <Label text="Nuit"/>
                </HBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>