<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" styleClass="main-container" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ServiceController">

    <Label text="GESTION DES SERVICES" styleClass="page-title"/>

    <HBox spacing="10" styleClass="search-container">
        <TextField fx:id="searchField" promptText="Rechercher un service..." HBox.hgrow="ALWAYS" styleClass="search-field"/>
        <ComboBox fx:id="filterType" promptText="Tous les types" prefWidth="150" styleClass="filter-combo"/>
        <Button text="Rechercher" onAction="#handleSearch" styleClass="search-button"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Liste des Services" styleClass="section-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnArchives" text="Archives" onAction="#handleVoirArchives" styleClass="btn-archive"/>
        <Button fx:id="btnRetour" text="⬅ Retour" onAction="#handleRetour" styleClass="btn-retour" visible="false"/>
        <Button text="+ Ajouter" onAction="#handleAjouter" styleClass="btn-add"/>
    </HBox>

    <GridPane styleClass="table-header" hgap="10" vgap="5">
        <columnConstraints>
            <ColumnConstraints percentWidth="20"/>
            <ColumnConstraints percentWidth="12"/>
            <ColumnConstraints percentWidth="12"/>
            <ColumnConstraints percentWidth="12"/>
            <ColumnConstraints percentWidth="12"/>
            <ColumnConstraints percentWidth="12"/>
            <ColumnConstraints percentWidth="20"/>
        </columnConstraints>
        <Label text="Titre" styleClass="table-header-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label text="Catégorie" styleClass="table-header-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Budget" styleClass="table-header-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <Label text="Début" styleClass="table-header-label" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
        <Label text="Fin" styleClass="table-header-label" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
        <Label text="Resp" styleClass="table-header-label" GridPane.columnIndex="5" GridPane.rowIndex="0"/>
        <Label text="Actions" styleClass="table-header-label" GridPane.columnIndex="6" GridPane.rowIndex="0"/>
    </GridPane>

    <ScrollPane fitToWidth="true" styleClass="table-scroll" VBox.vgrow="ALWAYS">
        <VBox fx:id="servicesContainer" spacing="1" styleClass="table-body"/>
    </ScrollPane>

</VBox>