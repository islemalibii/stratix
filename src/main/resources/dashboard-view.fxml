<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.DashboardController"
            style="-fx-background-color: linear-gradient(to bottom, #f0f9ff, #e6f0fa);">

    <top>
        <VBox spacing="15">
            <padding>
                <Insets top="10" left="35" right="35" bottom="10"/>
            </padding>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button onAction="#showDashboardFromButton" text="🏠 Dashboard"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showPlanningFromButton" text="📅 Planning"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showTachesFromButton" text="📋 Tâches"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showCalendarFromButton" text="📆 Calendrier"
                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button onAction="#showWhiteboardFromButton" text="📋 Whiteboard"
                        style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>

            <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #1e293b, #0f172a); -fx-background-radius: 15; -fx-padding: 20;">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="📊 TABLEAU DE BORD" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    <Label text="Vue d'ensemble de votre activité" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
                </VBox>

                <HBox style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 30; -fx-padding: 5 15;" alignment="CENTER">
                    <TextField fx:id="searchField" promptText="Rechercher..." style="-fx-background-color: transparent; -fx-text-fill: white;"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="25" style="-fx-background-color: transparent;">
                <padding>
                    <Insets top="30" right="35" bottom="30" left="35"/>
                </padding>

                <!-- RÉSULTATS DE RECHERCHE -->
                <VBox fx:id="searchResultsContainer" spacing="10" managed="false" visible="false" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="🔍 Résultats de recherche"/>
                    <ListView fx:id="searchResultsList" prefHeight="150" style="-fx-background-radius: 10; -fx-border-radius: 10;"/>
                </VBox>

                <!-- Section 1: Statistiques principales -->
                <VBox spacing="20">
                    <Label text="📈 APERÇU DES TÂCHES"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-background-color: white; -fx-padding: 10 20; -fx-background-radius: 50; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 0);"/>

                    <HBox spacing="20" style="-fx-alignment: center;">
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-min-width: 200; -fx-min-height: 180;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Circle radius="30" fill="#3b82f6" opacity="0.15"/>
                                <Label text="📋" style="-fx-font-size: 36px;"/>
                            </HBox>
                            <Label text="Total Tâches" style="-fx-font-size: 15px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                            <Label fx:id="lblTotalTaches" text="0" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        </VBox>
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-min-width: 200; -fx-min-height: 180;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Circle radius="30" fill="#f59e0b" opacity="0.15"/>
                                <Label text="⏳" style="-fx-font-size: 36px;"/>
                            </HBox>
                            <Label text="En cours" style="-fx-font-size: 15px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                            <Label fx:id="lblEnCours" text="0" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                        </VBox>
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-min-width: 200; -fx-min-height: 180;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Circle radius="30" fill="#10b981" opacity="0.15"/>
                                <Label text="✅" style="-fx-font-size: 36px;"/>
                            </HBox>
                            <Label text="Terminées" style="-fx-font-size: 15px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                            <Label fx:id="lblTerminees" text="0" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                        </VBox>
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-min-width: 200; -fx-min-height: 180;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Circle radius="30" fill="#f59e0b" opacity="0.15"/>
                                <Label text="📊" style="-fx-font-size: 36px;"/>
                            </HBox>
                            <Label text="À faire" style="-fx-font-size: 15px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                            <Label fx:id="lblAFaire" text="0" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Section 2: Employés -->
                <VBox spacing="20">
                    <Label text="👥 EMPLOYÉS"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-background-color: white; -fx-padding: 10 20; -fx-background-radius: 50; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 0);"/>

                    <HBox spacing="20" style="-fx-alignment: center;">
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-min-width: 200; -fx-min-height: 180;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Circle radius="30" fill="#8b5cf6" opacity="0.15"/>
                                <Label text="👥" style="-fx-font-size: 36px;"/>
                            </HBox>
                            <Label text="Total Employés" style="-fx-font-size: 15px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                            <Label fx:id="lblTotalEmployes" text="0" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #8b5cf6;"/>
                        </VBox>
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-min-width: 200; -fx-min-height: 180;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Circle radius="30" fill="#10b981" opacity="0.15"/>
                                <Label text="🟢" style="-fx-font-size: 36px;"/>
                            </HBox>
                            <Label text="En poste" style="-fx-font-size: 15px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                            <Label fx:id="lblEnPoste" text="0" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                        </VBox>
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-min-width: 200; -fx-min-height: 180;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Circle radius="30" fill="#ef4444" opacity="0.15"/>
                                <Label text="🔴" style="-fx-font-size: 36px;"/>
                            </HBox>
                            <Label text="Absents" style="-fx-font-size: 15px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                            <Label fx:id="lblAbsents" text="0" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                        </VBox>
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-min-width: 200; -fx-min-height: 180;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Circle radius="30" fill="#ef4444" opacity="0.15"/>
                                <Label text="⚠️" style="-fx-font-size: 36px;"/>
                            </HBox>
                            <Label text="En retard" style="-fx-font-size: 15px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                            <Label fx:id="lblEnRetard" text="0" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Section 3: Graphique et Citation -->
                <HBox spacing="20">
                    <!-- Graphique -->
                    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5);" HBox.hgrow="ALWAYS">
                        <Label text="📊 RÉPARTITION DES TÂCHES" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

                        <HBox spacing="30" alignment="CENTER">
                            <VBox spacing="15">
                                <HBox spacing="15" alignment="CENTER_LEFT">
                                    <Rectangle width="20" height="20" fill="#f59e0b" style="-fx-arc-width: 5; -fx-arc-height: 5;"/>
                                    <Label text="À faire" style="-fx-font-size: 14px; -fx-text-fill: #475569;"/>
                                    <Label fx:id="lblAFaireGraph" text="0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                                </HBox>
                                <HBox spacing="15" alignment="CENTER_LEFT">
                                    <Rectangle width="20" height="20" fill="#3b82f6" style="-fx-arc-width: 5; -fx-arc-height: 5;"/>
                                    <Label text="En cours" style="-fx-font-size: 14px; -fx-text-fill: #475569;"/>
                                    <Label fx:id="lblEnCoursGraph" text="0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
                                </HBox>
                                <HBox spacing="15" alignment="CENTER_LEFT">
                                    <Rectangle width="20" height="20" fill="#10b981" style="-fx-arc-width: 5; -fx-arc-height: 5;"/>
                                    <Label text="Terminées" style="-fx-font-size: 14px; -fx-text-fill: #475569;"/>
                                    <Label fx:id="lblTermineesGraph" text="0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                                </HBox>
                            </VBox>
                            <HBox spacing="20" alignment="BOTTOM_CENTER" prefHeight="120">
                                <VBox alignment="BOTTOM_CENTER" spacing="5">
                                    <Rectangle fx:id="barAFaire" width="40" height="0" style="-fx-fill: #f59e0b; -fx-arc-width: 10; -fx-arc-height: 10;"/>
                                    <Label text="À faire" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                                </VBox>
                                <VBox alignment="BOTTOM_CENTER" spacing="5">
                                    <Rectangle fx:id="barEnCours" width="40" height="0" style="-fx-fill: #3b82f6; -fx-arc-width: 10; -fx-arc-height: 10;"/>
                                    <Label text="En cours" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                                </VBox>
                                <VBox alignment="BOTTOM_CENTER" spacing="5">
                                    <Rectangle fx:id="barTerminees" width="40" height="0" style="-fx-fill: #10b981; -fx-arc-width: 10; -fx-arc-height: 10;"/>
                                    <Label text="Terminées" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                                </VBox>
                            </HBox>
                        </HBox>
                    </VBox>

                    <!-- Citation du jour -->
                    <VBox spacing="15" style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 0);" prefWidth="300">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="💬" style="-fx-font-size: 28px; -fx-text-fill: white;"/>
                            <Label text="CITATION DU JOUR" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                        </HBox>

                        <Label fx:id="lblCitation" wrapText="true"
                               style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-style: italic; -fx-padding: 10 0;"
                               text="Chargement de la citation..."/>

                        <HBox alignment="CENTER_RIGHT">
                            <Button fx:id="btnRefreshQuote" text="↻ Nouvelle citation"
                                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 8 15; -fx-background-radius: 20; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- ✅ NOUVEAU : Widget IA (placé entre les stats et les boutons) -->
                <VBox spacing="15">
                    <Label text="🤖 ASSISTANT IA"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-background-color: white; -fx-padding: 10 20; -fx-background-radius: 50; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 0);"/>
                    <VBox fx:id="chatWidgetContainer" spacing="10" />
                </VBox>

                <!-- Boutons de navigation -->
                <HBox spacing="20" alignment="CENTER" style="-fx-padding: 20 0 20 0;">
                    <Button text="📋 GESTION DES TÂCHES" onAction="#openTaches"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 15 35; -fx-background-radius: 50; -fx-cursor: hand;"/>
                    <Button text="📅 GESTION DES PLANNINGS" onAction="#openPlanning"
                            style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 15 35; -fx-background-radius: 50; -fx-cursor: hand;"/>
                    <Button text="🗓️ CALENDRIER" onAction="#openCalendar"
                            style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 15 35; -fx-background-radius: 50; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>