<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.DashboardController">

    <top>
        <VBox styleClass="header" spacing="10">
            <padding>
                <Insets top="20" right="30" bottom="10" left="30"/>
            </padding>
            <Label text="Tableau de Bord" styleClass="title"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="30" styleClass="content">
                <padding>
                    <Insets top="20" right="30" bottom="30" left="30"/>
                </padding>

                <!-- Stats Cards -->
                <HBox spacing="20" styleClass="stats-row">
                    <VBox styleClass="stat-card blue" HBox.hgrow="ALWAYS">
                        <Label text="📋" styleClass="stat-icon"/>
                        <Label text="Total Tâches" styleClass="stat-label"/>
                        <Label fx:id="lblTotalTaches" text="0" styleClass="stat-value"/>
                    </VBox>

                    <VBox styleClass="stat-card orange" HBox.hgrow="ALWAYS">
                        <Label text="⏳" styleClass="stat-icon"/>
                        <Label text="En cours" styleClass="stat-label"/>
                        <Label fx:id="lblEnCours" text="0" styleClass="stat-value"/>
                    </VBox>

                    <VBox styleClass="stat-card green" HBox.hgrow="ALWAYS">
                        <Label text="✅" styleClass="stat-icon"/>
                        <Label text="Terminées" styleClass="stat-label"/>
                        <Label fx:id="lblTerminees" text="0" styleClass="stat-value"/>
                    </VBox>

                    <VBox styleClass="stat-card red" HBox.hgrow="ALWAYS">
                        <Label text="⚠️" styleClass="stat-icon"/>
                        <Label text="En retard" styleClass="stat-label"/>
                        <Label fx:id="lblEnRetard" text="0" styleClass="stat-value"/>
                    </VBox>
                </HBox>

                <HBox spacing="20" styleClass="stats-row">
                    <VBox styleClass="stat-card purple" HBox.hgrow="ALWAYS">
                        <Label text="👥" styleClass="stat-icon"/>
                        <Label text="Total Employés" styleClass="stat-label"/>
                        <Label fx:id="lblTotalEmployes" text="0" styleClass="stat-value"/>
                    </VBox>

                    <VBox styleClass="stat-card teal" HBox.hgrow="ALWAYS">
                        <Label text="🟢" styleClass="stat-icon"/>
                        <Label text="En poste" styleClass="stat-label"/>
                        <Label fx:id="lblEnPoste" text="0" styleClass="stat-value"/>
                    </VBox>

                    <VBox styleClass="stat-card pink" HBox.hgrow="ALWAYS">
                        <Label text="🔴" styleClass="stat-icon"/>
                        <Label text="Absents" styleClass="stat-label"/>
                        <Label fx:id="lblAbsents" text="0" styleClass="stat-value"/>
                    </VBox>

                    <VBox styleClass="stat-card gray" HBox.hgrow="ALWAYS">
                        <Label text="📊" styleClass="stat-icon"/>
                        <Label text="À faire" styleClass="stat-label"/>
                        <Label fx:id="lblAFaire" text="0" styleClass="stat-value"/>
                    </VBox>
                </HBox>

                <!-- Navigation Rapide -->
                <HBox spacing="20" alignment="CENTER" styleClass="nav-row">
                    <Button text="📋 Gestion des Tâches" onAction="#openTaches" styleClass="nav-btn blue-btn"/>
                    <Button text="📅 Gestion des Plannings" onAction="#openPlanning" styleClass="nav-btn orange-btn"/>
                    <Button text="🗓️ Calendrier" onAction="#openCalendar" styleClass="nav-btn purple-btn"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>