<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" prefWidth="400" prefHeight="200"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.VisioController">

    <Label text="📹 VISIOCONFÉRENCE" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <VBox spacing="10" alignment="CENTER" VBox.vgrow="ALWAYS">
        <Label text="Cliquez sur 'Démarrer' pour ouvrir Jitsi Meet"/>
        <Label text="Salle: " style="-fx-font-weight: bold;">
            <graphic>
                <Label fx:id="roomIdLabel" text="En attente..."/>
            </graphic>
        </Label>
    </VBox>

    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="btnStartCall" text="🚀 Démarrer"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-padding: 8 16;"/>
        <Button fx:id="btnHangup" text="🔴 Raccrocher"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 8 16;"
                disable="true"/>
        <Button fx:id="btnCopyLink" text="📋 Copier"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 8 16;"/>
        <Button text="❌ Fermer" onAction="#closeWindow"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 8 16;"/>
    </HBox>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

</VBox>