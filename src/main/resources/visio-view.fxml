<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.VisioController"
            style="-fx-background-color: white;">

    <top>
        <VBox style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 12 20;">
                <Label text="stratiX " style="-fx-text-fill: #202124; -fx-font-size: 18px; -fx-font-weight: normal;">
                    <font>
                        <Font name="System Regular" size="8"/>
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="8" alignment="CENTER" style="-fx-background-color: #f1f3f4; -fx-background-radius: 20; -fx-padding: 6 12;">
                    <Label text="🔗" style="-fx-font-size: 14px;"/>
                    <Label fx:id="roomIdLabel" text="Chargement..." style="-fx-text-fill: #1a73e8; -fx-font-size: 13px; -fx-font-family: 'Monospaced';"/>
                </HBox>
            </HBox>


            <HBox alignment="CENTER" spacing="20" style="-fx-padding: 8 20 16 20;">
                <Button fx:id="btnStartCall" text="Démarrer"
                        onAction="#startCall"
                        style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: normal; -fx-background-radius: 20; -fx-padding: 8 24; -fx-cursor: hand;"/>

                <Button text="Copier le lien" onAction="#copyLink"
                        style="-fx-background-color: transparent; -fx-text-fill: #1a73e8; -fx-border-color: #dadce0; -fx-border-radius: 20; -fx-font-size: 14px; -fx-padding: 8 24; -fx-cursor: hand;"/>

                <Button text="Quitter" onAction="#closeWindow"
                        style="-fx-background-color: transparent; -fx-text-fill: #ea4335; -fx-border-color: #dadce0; -fx-border-radius: 20; -fx-font-size: 14px; -fx-padding: 8 24; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="browserContainer" style="-fx-background-color: #f8f9fa;">
            <VBox fx:id="placeholderContainer" alignment="CENTER" spacing="20">
                <Label text="📹" style="-fx-font-size: 80px; -fx-opacity: 0.3; -fx-text-fill: #5f6368;"/>
                <Label text="Prêt à démarrer la visioconférence"
                       style="-fx-text-fill: #5f6368; -fx-font-size: 16px;"/>
                <Label text="Cliquez sur 'Démarrer la visio' pour commencer"
                       style="-fx-text-fill: #80868b; -fx-font-size: 14px;"/>
            </VBox>
        </StackPane>
    </center>


</BorderPane>