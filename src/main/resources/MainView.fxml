<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<BorderPane prefHeight="600" prefWidth="1000" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MainController">

    <!-- Top bar pour basculer entre les modules -->
    <top>
        <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: #1e293b;" alignment="CENTER_LEFT">
            <Button onAction="#showDashboardFromButton" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5;" text="🏠 Dashboard" />
            <Button onAction="#showPlanningFromButton" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5;" text="📅 Planning" />
            <Button onAction="#showTachesFromButton" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5;" text="📋 Tâches" />
            <Button onAction="#showCalendarFromButton" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5;" text="📆 Calendrier" />
            <Button onAction="#showWhiteboardFromButton" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 5;" text="📋 Whiteboard" />
        </HBox>
    </top>

    <!-- Zone centrale où on va charger les vues -->
    <center>
        <StackPane fx:id="mainPane" />
    </center>

</BorderPane>