<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ProduitController"
            prefHeight="600" prefWidth="1000">



    <!-- Centre avec ListView -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <!-- Barre de recherche -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Rechercher:" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                <TextField fx:id="searchField" promptText="Nom du produit..."
                           HBox.hgrow="ALWAYS" prefWidth="200"/>
                <Button fx:id="btnSearch" text="Rechercher"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Button fx:id="btnClearSearch" text="Effacer"
                        style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Boutons d'action avec exports -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Gestion des Produits" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Boutons d'export -->
                <Button text="📊 Excel" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;"
                        onAction="#exporterProduitsExcel"/>
                <Button text="📄 PDF" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-cursor: hand;"
                        onAction="#exporterProduitsPDF"/>

                <!-- Boutons de gestion -->
                <Button text=" Ajouter" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;"
                        onAction="#ouvrirAjoutProduit"/>
                <Button text="✏ Modifier" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-cursor: hand;"
                        onAction="#ouvrirModifierProduit"/>
                <Button text="🗑 Supprimer" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;"
                        onAction="#supprimerProduit"/>
                <Button text=" Rafraîchir" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;"
                        onAction="#rafraichirListe"/>
            </HBox>

            <!-- ListView pour les produits -->
            <ListView fx:id="listViewProduits" VBox.vgrow="ALWAYS"/>

        </VBox>
    </center>

    <!-- Bas de page avec statistiques -->
    <bottom>
        <HBox spacing="20" style="-fx-background-color: #ecf0f1; -fx-padding: 15;" alignment="CENTER">
            <Label fx:id="statsTotal" text="Total produits: 0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label fx:id="statsStockFaible" text="Stock faible: 0" style="-fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
            <Label fx:id="statsValeurStock" text="Valeur stock: 0.00 DT" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
        </HBox>
    </bottom>
</BorderPane>