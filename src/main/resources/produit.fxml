<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.ProduitController"
            prefHeight="600" prefWidth="1000">

    <!-- Menu latéral gauche -->
    <left>
        <VBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 20;" prefWidth="200">
            <Label text="Tableau de Bord" style="-fx-text-fill: #ecf0f1; -fx-font-size: 16; -fx-font-weight: bold; -fx-padding: 0 0 10 0;"/>

            <Button text="📊 Employés" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" onAction="#naviguerEmployes"/>
            <Button text="📁 Projets" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" onAction="#naviguerProjets"/>
            <Button text="✅ Tâches" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" onAction="#naviguerTaches"/>
            <Button text="📦 Produits" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" onAction="#naviguerProduits"/>

            <!-- BOUTON RESSOURCES AJOUTÉ ICI -->
            <Button text="🔧 Ressources" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" onAction="#naviguerRessources"/>

            <Button text="📅 Prévoyance" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" onAction="#naviguerPrevoyance"/>
            <Button text="📈 Analyse" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" onAction="#naviguerAnalyse"/>

            <Separator style="-fx-background: #7f8c8d;"/>

            <Label text="L'ancienne à venir" style="-fx-text-fill: #ecf0f1; -fx-font-size: 14; -fx-font-weight: bold;"/>
            <Label text="📅 Produit 1 - 10/01/2025" style="-fx-text-fill: #bdc3c7;"/>
            <Label text="📅 Produit 2 - 27/08/2025" style="-fx-text-fill: #bdc3c7;"/>
            <Label text="📅 Produit 3 - 15/05/2025" style="-fx-text-fill: #bdc3c7;"/>
        </VBox>
    </left>

    <!-- Centre avec TableView -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Gestion des Produits" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="➕ Ajouter" style="-fx-background-color: #27ae60; -fx-text-fill: white;" onAction="#ouvrirAjoutProduit"/>
                <Button text="✏️ Modifier" style="-fx-background-color: #f39c12; -fx-text-fill: white;" onAction="#ouvrirModifierProduit"/>
                <Button text="🗑️ Supprimer" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" onAction="#supprimerProduit"/>
                <Button text="🔄 Rafraîchir" style="-fx-background-color: #3498db; -fx-text-fill: white;" onAction="#rafraichirListe"/>
            </HBox>

            <TableView fx:id="tableViewProduits" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="120"/>
                    <TableColumn fx:id="colDescription" text="Description" prefWidth="150"/>
                    <TableColumn fx:id="colCategorie" text="Catégorie" prefWidth="100"/>
                    <TableColumn fx:id="colPrix" text="Prix" prefWidth="80"/>
                    <TableColumn fx:id="colStockActuel" text="Stock" prefWidth="70"/>
                    <TableColumn fx:id="colStockMin" text="Stock Min" prefWidth="80"/>
                    <TableColumn fx:id="colDateCreation" text="Date Création" prefWidth="100"/>
                    <TableColumn fx:id="colRessources" text="Ressources" prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <!-- Bas de page avec statistiques -->
    <bottom>
        <HBox spacing="20" style="-fx-background-color: #ecf0f1; -fx-padding: 15;" alignment="CENTER">
            <Label fx:id="statsTotal" text="Total produits: 0" style="-fx-font-weight: bold;"/>
            <Label fx:id="statsStockFaible" text="Stock faible: 0" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>
            <Label fx:id="statsValeurStock" text="Valeur stock: 0.00 DT" style="-fx-font-weight: bold;"/>
        </HBox>
    </bottom>

</BorderPane>