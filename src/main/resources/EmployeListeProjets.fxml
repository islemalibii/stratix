<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="25" styleClass="root-container" xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.EmployeListeProjetController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <padding>
        <Insets bottom="30" left="40" right="40" top="30" />
    </padding>

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label fx:id="lblBienvenue" style="-fx-text-fill: #64748b; -fx-font-size: 24px; -fx-font-weight: bold;" text="Bonjour," />
            <Label text="Espace Collaborateur - Mes Projets" style="-fx-font-size: 14px; -fx-text-fill: #94a3b8;" />
        </VBox>
        <HBox spacing="10">
            <Button text="💬 Chat d'équipe" onAction="#ouvrirChat"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 20;"/>
            <Button text="⚙ Admin" onAction="#versBackOffice"
                    style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-background-radius: 20;"/>
        </HBox>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <TextField fx:id="searchField" onKeyReleased="#rechercherProjet"
                   promptText="🔍 Rechercher parmi mes projets..."
                   styleClass="modern-input" HBox.hgrow="ALWAYS" />
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="modern-scroll" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
        <content>
            <FlowPane fx:id="flowPaneProjets" hgap="30" vgap="30">
                <padding>
                    <Insets bottom="10" left="10" right="10" top="10" />
                </padding>
            </FlowPane>
        </content>
    </ScrollPane>
</VBox>