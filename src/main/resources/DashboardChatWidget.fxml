<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.DashboardChatWidget" spacing="10"
      style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);"
      prefWidth="350" prefHeight="400">

    <!-- En-têtee -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #2c3e50; -fx-background-radius: 10 10 0 0; -fx-padding: 12;">
        <Label text="🤖" style="-fx-font-size: 20;" />
        <VBox>
            <Label text="Assistant IA" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Label text="Groq Mixtral" style="-fx-font-size: 10; -fx-text-fill: #ecf0f1;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="🗑️" onAction="#clearChat" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;" />
    </HBox>

    <!-- Zone des messages -->
    <ScrollPane fx:id="scrollPane" VBox.vgrow="ALWAYS" style="-fx-background: #f8f9fa; -fx-background-color: #f8f9fa;">
        <VBox spacing="10" style="-fx-padding: 10;">
            <Label fx:id="welcomeMessage" wrapText="true" style="-fx-padding: 10; -fx-background-color: #f0f0f0; -fx-background-radius: 10; -fx-text-fill: #2c3e50;"
                   text="👋 Bonjour ! Je suis votre assistant IA. Posez-moi une question sur la gestion de projet, les tâches, ou tout autre sujet !" />
            <VBox fx:id="chatContainer" spacing="5" />
        </VBox>
    </ScrollPane>

    <!-- Indicateur de frappe -->
    <Label fx:id="typingIndicator" text="L'assistant tape..." style="-fx-padding: 5 10; -fx-text-fill: #7f8c8d; -fx-font-style: italic;" visible="false" managed="false" />

    <!-- Zone de saisie -->
    <HBox spacing="10" style="-fx-padding: 10; -fx-border-color: #ecf0f1; -fx-border-width: 1 0 0 0;">
        <TextField fx:id="inputField" promptText="Posez votre question..." HBox.hgrow="ALWAYS"
                   style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 8 12;" />
        <Button fx:id="sendButton" text="Envoyer" onAction="#sendMessage"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 15; -fx-cursor: hand;" />
    </HBox>
</VBox>